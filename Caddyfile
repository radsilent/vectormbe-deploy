# Caddy reverse proxy for VectorMBE
# Place your built UI files in ./www/ for static serving

:80 {
    # API proxy — long timeout for AI agent/chat (~60 s responses)
    handle_path /api/* {
        reverse_proxy vectormbe:8080 {
            transport http {
                response_header_timeout 120s
                read_timeout            120s
                write_timeout           120s
            }
        }
    }

    # Static UI files
    root * /var/www/vectormbe
    file_server
    try_files {path} {path}/ /index.html

    encode gzip

    header {
        X-Frame-Options "SAMEORIGIN"
        X-Content-Type-Options "nosniff"
        Referrer-Policy "strict-origin-when-cross-origin"
    }
}
