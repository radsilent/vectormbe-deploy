{
  "graph": {
    "metadata": {
      "name": "Submarine Integrated Combat System - SSN",
      "version": "1.0",
      "standard": "MIL-STD-1615, NAVSEA OD-45845",
      "created": "2026-05-31"
    },
    "nodes": [
      {"id": "SUB-001", "kind": "Block", "attributes": {"name": {"Text": "Submarine Combat and Propulsion System"}, "description": {"Text": "SSN nuclear fast attack submarine integrated systems: sonar, weapons, C4I, propulsion, navigation"}}},
      {"id": "SON-001", "kind": "Block", "attributes": {"name": {"Text": "Integrated Sonar Suite"}, "description": {"Text": "AN/BQQ-10 class multi-array broadband/narrowband suite, passive/active, LOFAR/DEMON processing"}}},
      {"id": "SON-BOW", "kind": "Component", "attributes": {"name": {"Text": "Bow Spherical Array"}, "description": {"Text": "1240-element cylindrical/spherical array, 1.35m radius, 10Hz-20kHz, 30.9 dB array gain"}}},
      {"id": "SON-TOWED", "kind": "Component", "attributes": {"name": {"Text": "TB-29A Thin-Line Towed Array"}, "description": {"Text": "480 elements, 160m aperture, 150m depth, 10-1000 Hz, 26.8 dB gain, VLA capable"}}},
      {"id": "SON-HF", "kind": "Component", "attributes": {"name": {"Text": "High-Frequency Sonar"}, "description": {"Text": "Mine detection sonar 20-100 kHz, forward-looking, 200m range, 0.25 deg bearing resolution"}}},
      {"id": "SON-PROC", "kind": "Component", "attributes": {"name": {"Text": "Sonar Processing Suite"}, "description": {"Text": "LOFAR/DEMON processor, 4096-pt FFT, 360 beams, 128 simultaneous tracks, TMA convergence 8 min"}}},
      {"id": "FCS-001", "kind": "Block", "attributes": {"name": {"Text": "Fire Control System"}, "description": {"Text": "AN/BSY-2 class combat control, weapon engagement sequencer, target data management, CIC integration"}}},
      {"id": "FCS-TGT", "kind": "Component", "attributes": {"name": {"Text": "Target Data Management"}, "description": {"Text": "Multi-target track file, TMA/KALMAN estimator, bearing-range-course-speed solution"}}},
      {"id": "FCS-WES", "kind": "Component", "attributes": {"name": {"Text": "Weapon Engagement Sequencer"}, "description": {"Text": "Pre-launch checklist automation, tube assignment, fire control solution transmission, post-launch tracking"}}},
      {"id": "WPN-001", "kind": "Block", "attributes": {"name": {"Text": "Weapons System"}, "description": {"Text": "4x 533mm torpedo tubes + 12 VLS cells. Weapons: MK-48, Tomahawk, TLAM, UUM-44 SUBROC"}}},
      {"id": "WPN-MK48", "kind": "Component", "attributes": {"name": {"Text": "MK-48 Mod 7 ADCAP Torpedo"}, "description": {"Text": "533mm heavy torpedo, 40 nm range, 55 kt speed, 650 lb PBXN-103 warhead, wire-guided + acoustic"}}},
      {"id": "WPN-TLAM", "kind": "Component", "attributes": {"name": {"Text": "Tomahawk Block IV TLAM"}, "description": {"Text": "Land attack cruise missile, 1000 nm range, terrain-following, GPS/INS/DSMAC guidance, 1000 lb warhead"}}},
      {"id": "WPN-VLS", "kind": "Component", "attributes": {"name": {"Text": "Vertical Launch System (12-cell)"}, "description": {"Text": "12x VLS cells, compatible with Tomahawk Block IV/V, future ASROC capability"}}},
      {"id": "WPN-TUBES", "kind": "Component", "attributes": {"name": {"Text": "Torpedo Tube Bank (4x533mm)"}, "description": {"Text": "4x MK-67 Mod 1 tubes, 533mm, water ram impulse launch, reloadable, 300m depth rated"}}},
      {"id": "COMMS-001", "kind": "Block", "attributes": {"name": {"Text": "Communications System"}, "description": {"Text": "Multiband C4I: ELF receive, VLF/LF (BRT-1), UHF/SHF SATCOM, periscope-depth HF/UHF, burst comms"}}},
      {"id": "COMMS-ELF", "kind": "Component", "attributes": {"name": {"Text": "ELF Receive Antenna"}, "description": {"Text": "76 Hz ELF receive, trailing wire antenna, submerged receive at mission depth, 1-bit message"}}},
      {"id": "COMMS-VLF", "kind": "Component", "attributes": {"name": {"Text": "VLF/LF Receive (BRT-1)"}, "description": {"Text": "14-30 kHz, trailing wire, receive-only at depth, TACAMO link compatible"}}},
      {"id": "COMMS-SAT", "kind": "Component", "attributes": {"name": {"Text": "SATCOM Terminal"}, "description": {"Text": "UHF/SHF SATCOM, mast-mounted, periscope-depth operation, AEHF/MILSTAR compatible"}}},
      {"id": "NAV-001", "kind": "Block", "attributes": {"name": {"Text": "Navigation System"}, "description": {"Text": "Integrated navigation: Ships inertial navigation SINS MK6, GPS, electromagnetic log, depth sounder"}}},
      {"id": "NAV-INS", "kind": "Component", "attributes": {"name": {"Text": "Ship's Inertial Navigation (SINS MK6)"}, "description": {"Text": "Ring laser gyro INS, drift <0.5 nm/hr CEP, continuous submerged navigation, attitude/heading reference"}}},
      {"id": "NAV-GPS", "kind": "Component", "attributes": {"name": {"Text": "GPS Receiver (DAGR/PLGR)"}, "description": {"Text": "Selective availability anti-spoofing GPS, position fix at periscope depth, 10m CEP"}}},
      {"id": "PROP-001", "kind": "Block", "attributes": {"name": {"Text": "Propulsion System"}, "description": {"Text": "Nuclear steam propulsion, S9G reactor, steam turbine, reduction gearbox, single shaft, 7-blade skewed prop"}}},
      {"id": "PROP-RXR", "kind": "Component", "attributes": {"name": {"Text": "S9G Reactor Plant"}, "description": {"Text": "PWR, 250 MWth, HEU core, 33-yr life-of-ship core, passive safety features"}}},
      {"id": "PROP-TURB", "kind": "Component", "attributes": {"name": {"Text": "Main Propulsion Turbine"}, "description": {"Text": "Steam turbine 40,000 SHP, 2-stage reduction gearbox, pumpjet or 7-blade propulsor"}}},
      {"id": "PROP-EMD", "kind": "Component", "attributes": {"name": {"Text": "Emergency Motor Drive"}, "description": {"Text": "400 HP electric motor, battery-fed, stern emergency propulsion, low-noise quiet ops"}}},
      {"id": "SIG-BEAR", "kind": "Signal", "attributes": {"name": {"Text": "Bearing Track Signal"}, "description": {"Text": "Processed sonar bearing reports to fire control, 0.5 deg accuracy, 1 Hz update"}}},
      {"id": "SIG-DEPH", "kind": "Signal", "attributes": {"name": {"Text": "Depth and Navigation Signal"}, "description": {"Text": "Own-ship position, course, speed, depth from SINS+GPS fusion, 0.5 nm/hr CEP"}}},
      {"id": "FUN-DETECT", "kind": "Function", "attributes": {"name": {"Text": "Passive Detection and Classification"}, "description": {"Text": "Detect and classify submerged contacts at >= 35 nm against surface combatants in SS4 sea state"}}},
      {"id": "FUN-ENGAGE", "kind": "Function", "attributes": {"name": {"Text": "Weapon Engagement"}, "description": {"Text": "Select, assign, and fire appropriate weapon against designated target within 60s of fire order"}}},
      {"id": "REQ-001", "kind": "Requirement", "attributes": {"name": {"Text": "Passive Detection Range"}, "description": {"Text": "Sonar suite shall detect surface combatant at >= 35 nm in sea state 4 using passive narrowband processing"}}},
      {"id": "REQ-002", "kind": "Requirement", "attributes": {"name": {"Text": "Track Capacity"}, "description": {"Text": "Fire control system shall maintain simultaneous track files for >= 128 contacts"}}},
      {"id": "REQ-003", "kind": "Requirement", "attributes": {"name": {"Text": "Weapon Response Time"}, "description": {"Text": "Time from fire order to weapon in water shall not exceed 60 seconds for torpedo engagement"}}},
      {"id": "REQ-004", "kind": "Requirement", "attributes": {"name": {"Text": "Navigation Accuracy"}, "description": {"Text": "Own-ship position accuracy shall be <= 0.5 nm CEP after 24 hours submerged using SINS alone"}}},
      {"id": "REQ-005", "kind": "Requirement", "attributes": {"name": {"Text": "Submerged Endurance"}, "description": {"Text": "Submarine shall sustain submerged operations for >= 90 days limited by crew provisions, not reactor fuel"}}},
      {"id": "REQ-006", "kind": "Requirement", "attributes": {"name": {"Text": "Acoustic Signature"}, "description": {"Text": "Radiated noise shall not exceed threshold X dB re 1 uPa at 1km at speeds <= 5 kt (classified threshold)"}}},
      {"id": "REQ-007", "kind": "Requirement", "attributes": {"name": {"Text": "Comms Receive at Depth"}, "description": {"Text": "ELF/VLF receive capability shall be maintained at all operating depths up to test depth"}}},
      {"id": "REQ-008", "kind": "Requirement", "attributes": {"name": {"Text": "Emergency Propulsion"}, "description": {"Text": "Emergency motor drive shall provide minimum 4 kt for 8 hours on battery power following main plant failure"}}},
      {"id": "REQ-009", "kind": "Requirement", "attributes": {"name": {"Text": "Torpedo Load Capacity"}, "description": {"Text": "Total weapon magazine capacity shall support >= 26 weapons (tubes + reload stowage)"}}},
      {"id": "REQ-010", "kind": "Requirement", "attributes": {"name": {"Text": "TMA Solution Time"}, "description": {"Text": "Target motion analysis shall converge to acceptable firing solution within 8 minutes of initial contact"}}}
    ],
