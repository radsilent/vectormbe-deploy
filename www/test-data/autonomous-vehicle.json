{
  "graph": {
    "metadata": {
      "name": "Autonomous Vehicle L4 System Model",
      "version": "1.3",
      "standard": "ISO 21448 (SOTIF), ISO 26262 ASIL-D, SAE J3016 L4",
      "created": "2026-05-31"
    },
    "nodes": [
      {"id": "AV-001", "kind": "Block", "attributes": {"name": {"Text": "L4 Autonomous Vehicle System"}, "description": {"Text": "SAE Level 4 AV: perception, prediction, planning, vehicle control, V2X, safety monitor. Urban ODD"}}},
      {"id": "PERC-001", "kind": "Block", "attributes": {"name": {"Text": "Perception System"}, "description": {"Text": "Multi-sensor object detection, classification, and tracking: LIDAR + 4D radar + 8 cameras, 80ms latency SLA"}}},
      {"id": "LIDAR-001", "kind": "Component", "attributes": {"name": {"Text": "Roof LIDAR (128-channel)"}, "description": {"Text": "128ch rotating LIDAR, 300m range, 10 Hz, 2.4M pts/s, 40 deg vertical FOV, IP69K"}}},
      {"id": "LIDAR-002", "kind": "Component", "attributes": {"name": {"Text": "Forward LIDAR (Solid-State)"}, "description": {"Text": "Solid-state forward LIDAR, 200m range, 20Hz, 120 deg H-FOV, no moving parts, redundant"}}},
      {"id": "RADAR-001", "kind": "Component", "attributes": {"name": {"Text": "Front 4D Imaging Radar"}, "description": {"Text": "Continental ARS540 class, 250m range, ±100 km/h Doppler, 0.3 deg az accuracy, all-weather"}}},
      {"id": "RADAR-002", "kind": "Component", "attributes": {"name": {"Text": "Corner Radar Array (3 units)"}, "description": {"Text": "3x short-range corner radars, 80m range, 150 deg H-FOV, parking and blind-spot coverage"}}},
      {"id": "CAM-001", "kind": "Component", "attributes": {"name": {"Text": "Front Telephoto Camera"}, "description": {"Text": "8.3 MP, 16mm focal length, 30 deg FOV, 250m detection range, HDR, traffic sign recognition"}}},
      {"id": "CAM-002", "kind": "Component", "attributes": {"name": {"Text": "Front Wide Camera"}, "description": {"Text": "8.3 MP, 2.8mm focal length, 100 deg FOV, lane marking and near-field object detection"}}},
      {"id": "CAM-003", "kind": "Component", "attributes": {"name": {"Text": "Surround Camera Ring (6 units)"}, "description": {"Text": "6x 2MP fisheye cameras, 190 deg FOV each, 360 deg coverage, parking and cross-traffic"}}},
      {"id": "FUSE-001", "kind": "Component", "attributes": {"name": {"Text": "Sensor Fusion EKF Engine"}, "description": {"Text": "Multi-sensor EKF/UKF, CTRV motion model, GNN association, 256 tracks, 20Hz update cycle"}}},
      {"id": "PRED-001", "kind": "Block", "attributes": {"name": {"Text": "Prediction Module"}, "description": {"Text": "Multi-agent trajectory prediction, 5s horizon, 50ms cycle, social force + transformer model"}}},
      {"id": "PLAN-001", "kind": "Block", "attributes": {"name": {"Text": "Planning System"}, "description": {"Text": "Hierarchical planner: route (global), behavioral (lane), motion (trajectory), 100ms cycle"}}},
      {"id": "PLAN-ROUTE", "kind": "Component", "attributes": {"name": {"Text": "Global Route Planner"}, "description": {"Text": "A*/Dijkstra on HD map graph, traffic-aware routing, 200km planning horizon, re-route < 500ms"}}},
      {"id": "PLAN-BEH", "kind": "Component", "attributes": {"name": {"Text": "Behavioral Planner"}, "description": {"Text": "Decision layer: lane change, merge, intersection, roundabout, STOP sign. MCTS + rule-based"}}},
      {"id": "PLAN-MOT", "kind": "Component", "attributes": {"name": {"Text": "Motion Planner"}, "description": {"Text": "Trajectory generation: MPC-based, 5s 50-step horizon, 0.1s dt, comfort jerk limit 2 m/s³"}}},
      {"id": "VEH-001", "kind": "Block", "attributes": {"name": {"Text": "Vehicle Control Interface"}, "description": {"Text": "By-wire interface: steer-by-wire ±540 deg, throttle-by-wire, brake-by-wire, ABS/ESC integration"}}},
      {"id": "VEH-STEER", "kind": "Component", "attributes": {"name": {"Text": "Steer-By-Wire Actuator"}, "description": {"Text": "Dual-motor EPS, 0.02 deg position accuracy, 50 Hz bandwidth, ASIL-D, 100ms fault response"}}},
      {"id": "VEH-BRAKE", "kind": "Component", "attributes": {"name": {"Text": "Brake-By-Wire System"}, "description": {"Text": "EHB + EPB, 0.5 g max regen blend, 150ms response to 0.8g, ASIL-D, manual override"}}},
      {"id": "HDMAP-001", "kind": "Component", "attributes": {"name": {"Text": "HD Map and Localisation"}, "description": {"Text": "Centimetric HD map, LiDAR-based localisation, ±0.05m accuracy, OTA map update, 200m ahead"}}},
      {"id": "GNSS-001", "kind": "Component", "attributes": {"name": {"Text": "GNSS/IMU Navigation"}, "description": {"Text": "Dual-antenna RTK-GNSS, 9-axis IMU, tightly-coupled fusion, 0.02m horizontal in open sky"}}},
      {"id": "V2X-001", "kind": "Component", "attributes": {"name": {"Text": "V2X Communication Unit"}, "description": {"Text": "C-V2X PC5 + DSRC 802.11p, 300m range, 10 Hz BSM broadcast, SPaT/MAP from infrastructure"}}},
      {"id": "SAFETY-001", "kind": "Block", "attributes": {"name": {"Text": "Safety Monitor and Watchdog"}, "description": {"Text": "ASIL-D safety island: plausibility checks, RSS safety envelope, min-risk condition manager"}}},
      {"id": "SAFETY-RSS", "kind": "Component", "attributes": {"name": {"Text": "RSS Safety Envelope Monitor"}, "description": {"Text": "Intel RSS model, per-agent safe longitudinal/lateral gaps, violation triggers safe stop command"}}},
      {"id": "SAFETY-WDG", "kind": "Component", "attributes": {"name": {"Text": "System Watchdog"}, "description": {"Text": "HW/SW watchdog, 10ms heartbeat, monitors all critical nodes, fallback to minimal risk condition"}}},
      {"id": "SIG-CLOUD", "kind": "Signal", "attributes": {"name": {"Text": "Perception Cloud Output"}, "description": {"Text": "Fused object list: ID, type, position, velocity, covariance, classification confidence at 20 Hz"}}},
      {"id": "SIG-TRAJ", "kind": "Signal", "attributes": {"name": {"Text": "Reference Trajectory Signal"}, "description": {"Text": "Planned trajectory: x/y/v/a/heading at 0.1s intervals, 5s horizon, 100ms update to controller"}}},
      {"id": "FUN-DETECT", "kind": "Function", "attributes": {"name": {"Text": "3D Object Detection"}, "description": {"Text": "Detect and classify all dynamic objects > 0.5 kg within 60m at night with < 0.01 FP/km"}}},
      {"id": "FUN-PLAN", "kind": "Function", "attributes": {"name": {"Text": "Safe Trajectory Planning"}, "description": {"Text": "Generate kinematically feasible, collision-free trajectory respecting traffic rules and comfort bounds"}}},
      {"id": "REQ-001", "kind": "Requirement", "attributes": {"name": {"Text": "Detection Latency"}, "description": {"Text": "End-to-end object detection latency from sensor acquisition to track output shall be <= 80 ms at 95th percentile"}}},
      {"id": "REQ-002", "kind": "Requirement", "attributes": {"name": {"Text": "Pedestrian Detection Range"}, "description": {"Text": "System shall detect pedestrians at >= 60 m range under nighttime conditions (10 lux ambient)"}}},
      {"id": "REQ-003", "kind": "Requirement", "attributes": {"name": {"Text": "Localisation Accuracy"}, "description": {"Text": "Ego-vehicle localisation shall achieve <= 0.1 m RMS horizontal accuracy using HD map fusion"}}},
      {"id": "REQ-004", "kind": "Requirement", "attributes": {"name": {"Text": "False Positive Rate"}, "description": {"Text": "Object detection false positive rate shall be <= 0.01 events per km in standard urban ODD"}}},
      {"id": "REQ-005", "kind": "Requirement", "attributes": {"name": {"Text": "Track Continuity"}, "description": {"Text": "Track continuity shall be maintained through a single sensor dropout of up to 500 ms"}}},
      {"id": "REQ-006", "kind": "Requirement", "attributes": {"name": {"Text": "Emergency Stop"}, "description": {"Text": "Safety monitor shall command a minimum risk condition stop within 200 ms of detecting unsafe system state"}}},
      {"id": "REQ-007", "kind": "Requirement", "attributes": {"name": {"Text": "Steer-By-Wire ASIL"}, "description": {"Text": "Steering actuation system shall comply with ISO 26262 ASIL-D with dual-channel architecture"}}},
      {"id": "REQ-008", "kind": "Requirement", "attributes": {"name": {"Text": "V2X Range"}, "description": {"Text": "V2X unit shall receive and process SPaT/MAP messages from infrastructure at >= 250 m range"}}}
    ],
