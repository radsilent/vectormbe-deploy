@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:   <http://www.w3.org/2002/07/owl#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix sosa:  <http://www.w3.org/ns/sosa/> .
@prefix ex:    <http://vectorowl.org/demo/iot-monitoring#> .

# ─── Ontology ─────────────────────────────────────────────────────────────────
<http://vectorowl.org/demo/iot-monitoring> a owl:Ontology ;
    rdfs:label "Smart Factory IoT Monitoring — Instance Dataset" ;
    rdfs:comment "SOSA-aligned sensor, observation, and feature instances for a manufacturing floor." .

# ─── Features of Interest ─────────────────────────────────────────────────────
ex:feat_cnc_spindle a owl:NamedIndividual , sosa:FeatureOfInterest ;
    rdfs:label "CNC Spindle Bearing #4" ;
    ex:assetTag "MACH-CNC-004" ;
    ex:location "Bay 3, Station 4" ;
    ex:criticality "High" .

ex:feat_hvac_unit a owl:NamedIndividual , sosa:FeatureOfInterest ;
    rdfs:label "HVAC Unit — Cleanroom A" ;
    ex:assetTag "HVAC-CLN-001" ;
    ex:location "Building 2, Cleanroom A" ;
    ex:criticality "Medium" .

ex:feat_conveyor_motor a owl:NamedIndividual , sosa:FeatureOfInterest ;
    rdfs:label "Conveyor Drive Motor" ;
    ex:assetTag "CONV-MOT-012" ;
    ex:location "Assembly Line 1" ;
    ex:criticality "High" .

ex:feat_tank_chemical a owl:NamedIndividual , sosa:FeatureOfInterest ;
    rdfs:label "Etching Bath Tank" ;
    ex:assetTag "TANK-ETCH-003" ;
    ex:location "Bay 7, Process Zone" ;
    ex:criticality "High" .

ex:feat_ambient_floor a owl:NamedIndividual , sosa:FeatureOfInterest ;
    rdfs:label "Factory Floor Ambient Conditions" ;
    ex:location "Building 1, General" ;
    ex:criticality "Low" .

# ─── Observable Properties ────────────────────────────────────────────────────
ex:prop_vibration a owl:NamedIndividual , sosa:ObservableProperty ;
    rdfs:label "Vibration (RMS)" ;
    ex:unit "mm/s" .

ex:prop_temperature a owl:NamedIndividual , sosa:ObservableProperty ;
    rdfs:label "Temperature" ;
    ex:unit "°C" .

ex:prop_current a owl:NamedIndividual , sosa:ObservableProperty ;
    rdfs:label "Motor Phase Current" ;
    ex:unit "A" .

ex:prop_ph a owl:NamedIndividual , sosa:ObservableProperty ;
    rdfs:label "Chemical pH" ;
    ex:unit "pH" .

ex:prop_humidity a owl:NamedIndividual , sosa:ObservableProperty ;
    rdfs:label "Relative Humidity" ;
    ex:unit "%" .

ex:prop_pressure a owl:NamedIndividual , sosa:ObservableProperty ;
    rdfs:label "Differential Pressure" ;
    ex:unit "Pa" .

# ─── Sensors ──────────────────────────────────────────────────────────────────
ex:sensor_vib_cnc a owl:NamedIndividual , sosa:Sensor ;
    rdfs:label "MEMS Vibration Sensor — CNC#4" ;
    ex:serialNumber "VIB-9924-A" ;
    ex:protocol "MQTT" ;
    ex:sampleRate_Hz "1000"^^xsd:integer ;
    ex:installDate "2024-03-15" ;
    sosa:observes ex:prop_vibration ;
    sosa:isHostedBy ex:feat_cnc_spindle .

ex:sensor_temp_cnc a owl:NamedIndividual , sosa:Sensor ;
    rdfs:label "PT100 Temperature — CNC#4 Bearing" ;
    ex:serialNumber "TMP-0443-B" ;
    ex:protocol "Modbus RTU" ;
    ex:accuracy_degC "0.15"^^xsd:decimal ;
    ex:installDate "2024-03-15" ;
    sosa:observes ex:prop_temperature ;
    sosa:isHostedBy ex:feat_cnc_spindle .

ex:sensor_temp_hvac a owl:NamedIndividual , sosa:Sensor ;
    rdfs:label "Thermocouple — HVAC Cleanroom A Supply" ;
    ex:serialNumber "TMP-0887-C" ;
    ex:protocol "BACnet" ;
    ex:accuracy_degC "0.5"^^xsd:decimal ;
    sosa:observes ex:prop_temperature ;
    sosa:isHostedBy ex:feat_hvac_unit .

ex:sensor_hum_hvac a owl:NamedIndividual , sosa:Sensor ;
    rdfs:label "Capacitive Humidity — HVAC Cleanroom A" ;
    ex:serialNumber "HUM-2210-A" ;
    ex:protocol "BACnet" ;
    sosa:observes ex:prop_humidity ;
    sosa:isHostedBy ex:feat_hvac_unit .

ex:sensor_press_hvac a owl:NamedIndividual , sosa:Sensor ;
    rdfs:label "Differential Pressure — Cleanroom A" ;
    ex:serialNumber "PRS-0034-B" ;
    ex:protocol "BACnet" ;
    sosa:observes ex:prop_pressure ;
    sosa:isHostedBy ex:feat_hvac_unit .

ex:sensor_curr_motor a owl:NamedIndividual , sosa:Sensor ;
    rdfs:label "Current Transformer — Conveyor Drive" ;
    ex:serialNumber "CUR-1182-A" ;
    ex:protocol "OPC-UA" ;
    ex:range_A "0-200"^^xsd:string ;
    sosa:observes ex:prop_current ;
    sosa:isHostedBy ex:feat_conveyor_motor .

ex:sensor_ph_tank a owl:NamedIndividual , sosa:Sensor ;
    rdfs:label "pH Electrode — Etching Bath" ;
    ex:serialNumber "PH-7731-D" ;
    ex:protocol "4-20mA" ;
    ex:calibrationDate "2025-01-10" ;
    sosa:observes ex:prop_ph ;
    sosa:isHostedBy ex:feat_tank_chemical .

ex:sensor_temp_tank a owl:NamedIndividual , sosa:Sensor ;
    rdfs:label "RTD Temperature — Etching Bath" ;
    ex:serialNumber "TMP-5560-C" ;
    ex:protocol "4-20mA" ;
    sosa:observes ex:prop_temperature ;
    sosa:isHostedBy ex:feat_tank_chemical .

ex:sensor_temp_ambient a owl:NamedIndividual , sosa:Sensor ;
    rdfs:label "Ambient Temperature — Floor" ;
    ex:serialNumber "TMP-ENV-001" ;
    ex:protocol "LoRaWAN" ;
    sosa:observes ex:prop_temperature ;
    sosa:isHostedBy ex:feat_ambient_floor .

# ─── Sensor Platforms ─────────────────────────────────────────────────────────
ex:platform_edge_node_bay3 a owl:NamedIndividual , sosa:Platform ;
    rdfs:label "Edge Node — Bay 3" ;
    ex:manufacturer "Siemens" ;
    ex:model "SIMATIC IPC427E" ;
    ex:ipAddress "192.168.10.43" ;
    sosa:hosts ex:sensor_vib_cnc ;
    sosa:hosts ex:sensor_temp_cnc .

ex:platform_bms_controller a owl:NamedIndividual , sosa:Platform ;
    rdfs:label "BMS Controller — Building 2" ;
    ex:manufacturer "Honeywell" ;
    ex:model "WEBstation-AX" ;
    ex:ipAddress "192.168.20.11" ;
    sosa:hosts ex:sensor_temp_hvac ;
    sosa:hosts ex:sensor_hum_hvac ;
    sosa:hosts ex:sensor_press_hvac .

# ─── Sample Observations ──────────────────────────────────────────────────────
ex:obs_vib_001 a owl:NamedIndividual , sosa:Observation ;
    rdfs:label "Vibration Obs #001 — CNC#4" ;
    sosa:madeBySensor ex:sensor_vib_cnc ;
    sosa:observedProperty ex:prop_vibration ;
    sosa:hasFeatureOfInterest ex:feat_cnc_spindle ;
    sosa:resultTime "2025-05-30T08:14:22Z"^^xsd:dateTime ;
    sosa:hasSimpleResult "4.72"^^xsd:decimal ;
    ex:alert "false"^^xsd:boolean .

ex:obs_vib_002 a owl:NamedIndividual , sosa:Observation ;
    rdfs:label "Vibration Obs #002 — CNC#4 (ALERT)" ;
    sosa:madeBySensor ex:sensor_vib_cnc ;
    sosa:observedProperty ex:prop_vibration ;
    sosa:hasFeatureOfInterest ex:feat_cnc_spindle ;
    sosa:resultTime "2025-05-30T09:02:11Z"^^xsd:dateTime ;
    sosa:hasSimpleResult "12.34"^^xsd:decimal ;
    ex:alert "true"^^xsd:boolean ;
    ex:alertMessage "Vibration exceeds warning threshold of 10 mm/s" .

ex:obs_temp_cnc_001 a owl:NamedIndividual , sosa:Observation ;
    rdfs:label "Bearing Temp Obs #001 — CNC#4" ;
    sosa:madeBySensor ex:sensor_temp_cnc ;
    sosa:observedProperty ex:prop_temperature ;
    sosa:hasFeatureOfInterest ex:feat_cnc_spindle ;
    sosa:resultTime "2025-05-30T09:02:11Z"^^xsd:dateTime ;
    sosa:hasSimpleResult "78.4"^^xsd:decimal .

ex:obs_ph_001 a owl:NamedIndividual , sosa:Observation ;
    rdfs:label "Etch Bath pH Obs #001" ;
    sosa:madeBySensor ex:sensor_ph_tank ;
    sosa:observedProperty ex:prop_ph ;
    sosa:hasFeatureOfInterest ex:feat_tank_chemical ;
    sosa:resultTime "2025-05-30T07:30:00Z"^^xsd:dateTime ;
    sosa:hasSimpleResult "3.21"^^xsd:decimal .

# ─── Actuatable Properties & Actuators ───────────────────────────────────────
ex:prop_valve_position a owl:NamedIndividual , sosa:ActuatableProperty ;
    rdfs:label "Chemical Feed Valve Position" ;
    ex:unit "% open" .

ex:actuator_feed_valve a owl:NamedIndividual , sosa:Actuator ;
    rdfs:label "Chemical Feed Valve — Etching Bath" ;
    ex:serialNumber "ACT-7701-A" ;
    ex:protocol "4-20mA" ;
    sosa:actsOnProperty ex:prop_valve_position .

# ─── Sampling & Procedures ────────────────────────────────────────────────────
ex:proc_vibration_rms a owl:NamedIndividual , sosa:Procedure ;
    rdfs:label "RMS Vibration Measurement Procedure" ;
    ex:standard "ISO 10816-3" ;
    ex:windowSize_ms "500"^^xsd:integer .

ex:sample_bearing_oil a owl:NamedIndividual , sosa:Sample ;
    rdfs:label "Bearing Oil Sample #20250528" ;
    ex:collectedDate "2025-05-28" ;
    ex:labReference "OIL-2025-0248" ;
    sosa:isSampleOf ex:feat_cnc_spindle .
