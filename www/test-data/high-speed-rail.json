{
  "graph": {
    "metadata": {
      "name": "High-Speed Rail EMU System Model",
      "version": "1.1",
      "standard": "EN 50126, EN 50128 SIL3, IEC 61375, TSI HS RST",
      "created": "2026-05-31"
    },
    "nodes": [
      {"id": "HSR-001", "kind": "Block", "attributes": {"name": {"Text": "HSR EMU 350 km/h System"}, "description": {"Text": "16-car electric multiple unit, 350 km/h service speed, 17.1 MW continuous traction power"}}},
      {"id": "TRACT-001", "kind": "Block", "attributes": {"name": {"Text": "Traction System"}, "description": {"Text": "Distributed traction: 14 motor cars, 56 powered axles, PMSM drives, 25 kV AC input"}}},
      {"id": "PANTO-001", "kind": "Component", "attributes": {"name": {"Text": "Roof Pantograph (ASP-1)"}, "description": {"Text": "Single-arm pantograph, 25 kV 50 Hz, contact force 70-120 N, max 350 km/h, de-icing heated"}}},
      {"id": "TRSF-001", "kind": "Component", "attributes": {"name": {"Text": "Main Transformer"}, "description": {"Text": "Traction transformer 25kV/1500V, 10.8 MVA per unit, oil-cooled, 4 secondary windings"}}},
      {"id": "CONV-001", "kind": "Component", "attributes": {"name": {"Text": "4-Quadrant Converter (4QC)"}, "description": {"Text": "IGBT 4QC, 3.6 MW per unit, PWM 2.5 kHz, unity power factor, regen capable to grid"}}},
      {"id": "VVVF-001", "kind": "Component", "attributes": {"name": {"Text": "VVVF Traction Inverter"}, "description": {"Text": "3-phase IGBT inverter, 1800V DC link, 305 kW per axle output, SiC modules 350 km/h"}}},
      {"id": "MOTOR-001", "kind": "Component", "attributes": {"name": {"Text": "PMSM Traction Motor (per axle)"}, "description": {"Text": "Permanent magnet synchronous motor, 305 kW cont / 380 kW peak, 2050 Nm, IP55, gearbox integrated"}}},
      {"id": "BRAKE-001", "kind": "Block", "attributes": {"name": {"Text": "Braking System"}, "description": {"Text": "Combined electric regen + friction disc brakes, 1.29 m/s² emergency, UIC 544-1 Cat B+"}}},
      {"id": "BRAKE-REGEN", "kind": "Component", "attributes": {"name": {"Text": "Regenerative Brake Inverter"}, "description": {"Text": "Motor-as-generator mode, 280 kN max braking force, 88% efficiency, energy fed back to OCS or resistors"}}},
      {"id": "BRAKE-DISC", "kind": "Component", "attributes": {"name": {"Text": "Disc Brake Units (3x per axle)"}, "description": {"Text": "Axle-mounted disc brakes, 640mm dia, electro-pneumatic caliper, WSP (anti-skid) controlled"}}},
      {"id": "BRAKE-MAG", "kind": "Component", "attributes": {"name": {"Text": "Linear Eddy Current Brake"}, "description": {"Text": "Track-mounted eddy current brake, 20 kN per unit, speed-dependent, noise-free, no mechanical wear"}}},
      {"id": "ETCS-001", "kind": "Block", "attributes": {"name": {"Text": "ETCS On-Board Unit (OBU)"}, "description": {"Text": "ETCS Level 2 OBU, Eurobalise reader, GSM-R interface, SIL4 certified EN 50128, DMI display"}}},
      {"id": "ETCS-ATC", "kind": "Component", "attributes": {"name": {"Text": "Automatic Train Control (ATC)"}, "description": {"Text": "Speed supervision and emergency brake application, MA from RBC, braking curve calculation"}}},
      {"id": "ETCS-ATO", "kind": "Component", "attributes": {"name": {"Text": "Automatic Train Operation (ATO)"}, "description": {"Text": "Station-to-station driving, speed optimisation, docking accuracy ±0.3m, GoA2/GoA3 capable"}}},
      {"id": "CRASH-001", "kind": "Block", "attributes": {"name": {"Text": "Crashworthiness Structure"}, "description": {"Text": "EN 15227 Cat C-I compliant: energy absorbing nose, anti-climb couplers, structural survival zone"}}},
      {"id": "CRASH-NOSE", "kind": "Component", "attributes": {"name": {"Text": "Deformable Nose Cone"}, "description": {"Text": "CFRP/aluminium crash absorber, 2.0 MJ energy absorption, controlled progressive crush"}}},
      {"id": "CRASH-COUPLER", "kind": "Component", "attributes": {"name": {"Text": "Anti-Climb Semi-Permanent Coupler"}, "description": {"Text": "Voith semi-perm coupler with anti-climb device, 3.0 MJ energy absorption per interface"}}},
      {"id": "HVAC-001", "kind": "Component", "attributes": {"name": {"Text": "Passenger HVAC System"}, "description": {"Text": "Per-car HVAC, heat pump cycle, 22±2°C target, air quality CO2 < 2500 ppm, EN 14750 certified"}}},
      {"id": "DOOR-001", "kind": "Component", "attributes": {"name": {"Text": "Passenger Door System"}, "description": {"Text": "Bi-parting sliding plug doors, 1300mm clear width, <3s open/close, obstacle detection, SIL2"}}},
      {"id": "DIAG-001", "kind": "Block", "attributes": {"name": {"Text": "On-Board Diagnostics (TCMS/OBDMS)"}, "description": {"Text": "Train Control and Monitoring System: MVB/WTB backbone, condition monitoring, remote diagnostics"}}},
      {"id": "DIAG-TCMS", "kind": "Component", "attributes": {"name": {"Text": "TCMS Central Unit"}, "description": {"Text": "MVB train bus master, IEC 61375, 2048 process variables, event logging 48h, WLAN GSM-R uplink"}}},
      {"id": "DIAG-CMS", "kind": "Component", "attributes": {"name": {"Text": "Condition Monitoring (CMS)"}, "description": {"Text": "Axle bearing temperature, pantograph force, bogie acceleration, traction health index, MTTF analysis"}}},
      {"id": "SIG-TRAC", "kind": "Signal", "attributes": {"name": {"Text": "Traction Command Signal"}, "description": {"Text": "Traction effort demand from TCMS to VVVF inverters, -420 to +420 kN range, CAN/MVB"}}},
      {"id": "SIG-VEL", "kind": "Signal", "attributes": {"name": {"Text": "Train Speed Signal"}, "description": {"Text": "Tachometer + Doppler radar fused speed, ±0.5 km/h accuracy, 50ms update, ATP interface"}}},
      {"id": "FUN-TRAC", "kind": "Function", "attributes": {"name": {"Text": "Traction Force Generation"}, "description": {"Text": "Convert 25kV OCS power to axle traction force 0-300 km/h, maintain adhesion within mu limits"}}},
      {"id": "FUN-SAFE", "kind": "Function", "attributes": {"name": {"Text": "Safe Speed Supervision"}, "description": {"Text": "Continuous comparison of actual speed against movement authority; command emergency brake on violation"}}},
      {"id": "REQ-001", "kind": "Requirement", "attributes": {"name": {"Text": "Service Speed"}, "description": {"Text": "The EMU shall sustain 350 km/h service speed on 35 per mille grade with AW2 passenger load"}}},
      {"id": "REQ-002", "kind": "Requirement", "attributes": {"name": {"Text": "Emergency Braking Performance"}, "description": {"Text": "Emergency braking deceleration shall be >= 1.29 m/s² from 350 km/h with UIC 544-1 Cat B+ compliance"}}},
      {"id": "REQ-003", "kind": "Requirement", "attributes": {"name": {"Text": "Energy Recuperation"}, "description": {"Text": "Regenerative braking shall recover >= 30% of traction energy over a standard commuter duty cycle"}}},
      {"id": "REQ-004", "kind": "Requirement", "attributes": {"name": {"Text": "ETCS SIL Level"}, "description": {"Text": "ETCS on-board unit shall be certified to SIL 4 per EN 50128 and interoperable per TSI CCS"}}},
      {"id": "REQ-005", "kind": "Requirement", "attributes": {"name": {"Text": "Crashworthiness"}, "description": {"Text": "The carbody structure shall comply with EN 15227 Category C-I with survival space maintained"}}},
      {"id": "REQ-006", "kind": "Requirement", "attributes": {"name": {"Text": "Traction Power Factor"}, "description": {"Text": "Power factor at pantograph shall be >= 0.99 across 25-100% of rated power"}}},
      {"id": "REQ-007", "kind": "Requirement", "attributes": {"name": {"Text": "HVAC Temperature Accuracy"}, "description": {"Text": "Passenger saloon temperature shall be maintained at 22 ± 2°C in ambient -25°C to +40°C"}}},
      {"id": "REQ-008", "kind": "Requirement", "attributes": {"name": {"Text": "Door Reliability"}, "description": {"Text": "Passenger door MDBF shall be >= 300,000 cycles; obstacle detection response <= 150 ms"}}},
      {"id": "REQ-009", "kind": "Requirement", "attributes": {"name": {"Text": "Diagnostics Availability"}, "description": {"Text": "TCMS shall achieve >= 99.95% availability; remote diagnostics upload within 10 minutes of depot arrival"}}},
      {"id": "REQ-010", "kind": "Requirement", "attributes": {"name": {"Text": "Wheel Slip Control Response"}, "description": {"Text": "Slip/slide protection system shall detect and respond to wheel slip > 10% within 50 ms"}}}
    ],
