/* ---- MATERIAL SPECIFICATIONS ---- */
#300 = MATERIAL('AlLi_2050_T84','Aluminium-Lithium 2050 T84',
     ('UTS 490 MPa','E=77 GPa','Density 2.68 g/cc','AMS 2770 / AMS 2658','Primary frames and skin'));
#301 = MATERIAL('AlLi_2099_T83','Aluminium-Lithium 2099 T83',
     ('UTS 560 MPa','E=78 GPa','Density 2.63 g/cc','Better corrosion resistance','Keel and lower skin'));
#302 = MATERIAL('Ti_6Al_4V','Titanium Ti-6Al-4V ELI',
     ('UTS 1000 MPa','Density 4.43 g/cc','AMS 4928','Hinges, fittings, keel forward fitting'));
#303 = MATERIAL('CFRP_IM7_977','CFRP IM7 / Cytec 977-2 Prepreg',
     ('Longitudinal UTS 2620 MPa','E_11=155 GPa','Density 1.57 g/cc','Floor beams, shelf structures'));

/* ---- KEY DESIGN PROPERTIES ---- */
/* Section Length                : 9.14 m (Sta 100 to Sta 400) */
/* Outer Diameter                : 6.98 m */
/* Max Cabin Width               : 6.19 m (twin-aisle) */
/* Max Differential Pressure     : 9.4 psi (CS-25.365) */
/* Service Life (structural)     : 100,000 FH / 40,000 FC */
/* Fatigue Spectrum              : Short-medium range, 3-4 hr sectors */
/* Frame Pitch                   : 508 mm (typical) */
/* Stringer Count (circumference): 76 stringers */
/* Fastener system               : Hi-Lok titanium + CherryMax blind fasteners */
/* Fail-safe design concept      : Damage tolerant per CS-25.571 */
/* Certification Basis           : CS-25 / FAR Part 25 / AC 25.571-1D */

ENDSEC;
