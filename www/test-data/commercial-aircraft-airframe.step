ISO-10303-21;
HEADER;
FILE_DESCRIPTION(('Commercial Transport Aircraft Airframe Assembly'
  'AP214 Mechanical Design - Aerospace'
  'Aircraft: Narrow-body twin-engine commercial transport'
  'Assembly: Full airframe structural decomposition'
  'Standard: MIL-STD-31000B, ARP4754A, AS9100D'),
  '2;1');
FILE_NAME('/aircraft/CommercialAirframe_Assembly.step',
  '2026-06-08T10:00:00',
  ('Airframe Structures Group','Aerospace Systems Engineering'),
  ('VectorMBE CAD Export'),
  'VectorMBE STEP AP214 Exporter v2.4',
  'Commercial Airframe Rev A',
  'DISTRIBUTION UNLIMITED');
FILE_SCHEMA(('AUTOMOTIVE_DESIGN { 1 0 10303 214 3 1 1 1 }'));
ENDSEC;

DATA;

/* ============================================================ */
/* APPLICATION CONTEXT                                           */
/* ============================================================ */
#1 = APPLICATION_CONTEXT('automotive design');
