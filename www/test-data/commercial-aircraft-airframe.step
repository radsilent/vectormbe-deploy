/* ============================================================ */
/* TOP-LEVEL ASSEMBLY: AIRFRAME                                  */
/* Narrow-body twin-engine commercial transport, ~180 PAX        */
/* MTOW 79 000 kg, wingspan 35.8 m, length 44.5 m               */
/* ============================================================ */
#10 = PRODUCT('ACF-001','Commercial Aircraft Airframe',
     'Full airframe assembly: fuselage, wings, empennage, nacelles, landing gear, flight controls',(#3));
