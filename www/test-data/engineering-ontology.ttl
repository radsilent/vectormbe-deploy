@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix vowl: <http://vectorowl.org/ontology/engineering#> .
@prefix cad: <http://vectorowl.org/ontology/cad#> .
@prefix cae: <http://vectorowl.org/ontology/cae#> .
@prefix plm: <http://vectorowl.org/ontology/plm#> .

# ─── Classes ──────────────────────────────────────────────────────────────────

cad:Part a owl:Class ;
    rdfs:label "CAD Part" ;
    rdfs:comment "A discrete solid body designed in a CAD system." .

cad:Assembly a owl:Class ;
    rdfs:label "CAD Assembly" ;
    rdfs:comment "A collection of parts and sub-assemblies." .

cad:Surface a owl:Class ;
    rdfs:label "CAD Surface" ;
    rdfs:comment "A topological face or surface region on a part." .

cae:SimulationRun a owl:Class ;
    rdfs:label "Simulation Run" ;
    rdfs:comment "A single execution of a CAE solver with defined inputs and outputs." .

cae:BoundaryCondition a owl:Class ;
    rdfs:label "Boundary Condition" ;
    rdfs:comment "A constraint or load applied to a model in a simulation." .

cae:NamedSelection a owl:Class ;
    rdfs:label "Named Selection" ;
    rdfs:comment "A user-defined set of geometric entities (faces, edges, bodies) identified by name for applying loads or constraints." .

cae:SimulationResult a owl:Class ;
    rdfs:label "Simulation Result" ;
    rdfs:comment "Aggregated results from a simulation run (max stress, max displacement, etc.)." .

cae:SimulationNode a owl:Class ;
    rdfs:label "Simulation Node" ;
    rdfs:comment "A single nodal result point from a finite element mesh." .

plm:Material a owl:Class ;
    rdfs:label "Engineering Material" ;
    rdfs:comment "A material with certified mechanical, thermal, and chemical properties." .

plm:Requirement a owl:Class ;
    rdfs:label "Requirement" ;
    rdfs:comment "A formal system or component requirement." .

# ─── Object Properties ────────────────────────────────────────────────────────

cad:hasMaterial a owl:ObjectProperty ;
    rdfs:domain cad:Part ;
    rdfs:range plm:Material ;
    rdfs:label "has material" .

cad:hasSurface a owl:ObjectProperty ;
    rdfs:domain cad:Part ;
    rdfs:range cad:Surface ;
    rdfs:label "has surface" .

cae:analyzes a owl:ObjectProperty ;
    rdfs:domain cae:SimulationRun ;
    rdfs:range cad:Part ;
    rdfs:label "analyzes" .

cae:hasBoundaryCondition a owl:ObjectProperty ;
    rdfs:domain cae:SimulationRun ;
    rdfs:range cae:BoundaryCondition ;
    rdfs:label "has boundary condition" .

cae:hasNamedSelection a owl:ObjectProperty ;
    rdfs:domain cae:SimulationRun ;
    rdfs:range cae:NamedSelection ;
    rdfs:label "has named selection" .

cae:hasResult a owl:ObjectProperty ;
    rdfs:domain cae:SimulationRun ;
    rdfs:range cae:SimulationResult ;
    rdfs:label "has result" .

cae:producesNodeResult a owl:ObjectProperty ;
    rdfs:domain cae:SimulationRun ;
    rdfs:range cae:SimulationNode ;
    rdfs:label "produces node result" .

cae:mapsToCADSurface a owl:ObjectProperty ;
    rdfs:domain cae:SimulationNode ;
    rdfs:range cad:Surface ;
    rdfs:label "maps to CAD surface" .

cae:appliedTo a owl:ObjectProperty ;
    rdfs:domain cae:BoundaryCondition ;
    rdfs:range cae:NamedSelection ;
    rdfs:label "applied to" .

plm:satisfiesRequirement a owl:ObjectProperty ;
    rdfs:domain cae:SimulationResult ;
    rdfs:range plm:Requirement ;
    rdfs:label "satisfies requirement" .

plm:derivedFrom a owl:ObjectProperty ;
    rdfs:domain cae:SimulationRun ;
    rdfs:range cad:Part ;
    rdfs:label "derived from" .

# ─── Datatype Properties ──────────────────────────────────────────────────────

cad:hasVolume a owl:DatatypeProperty ;
    rdfs:domain cad:Part ;
    rdfs:range xsd:decimal ;
    rdfs:label "volume in cubic millimeters" .

cad:hasMass a owl:DatatypeProperty ;
    rdfs:domain cad:Part ;
    rdfs:range xsd:decimal ;
    rdfs:label "mass in kilograms" .

cad:hasCADFileURI a owl:DatatypeProperty ;
    rdfs:domain cad:Part ;
    rdfs:range xsd:anyURI ;
    rdfs:label "CAD file URI" .

cad:hasSTEPFileURI a owl:DatatypeProperty ;
    rdfs:domain cad:Part ;
    rdfs:range xsd:anyURI ;
    rdfs:label "STEP file URI" .

cae:hasUnitSystem a owl:DatatypeProperty ;
    rdfs:domain cae:SimulationRun ;
    rdfs:range xsd:string ;
    rdfs:label "unit system" .

cae:hasSolver a owl:DatatypeProperty ;
    rdfs:domain cae:SimulationRun ;
    rdfs:range xsd:string ;
    rdfs:label "solver name" .

cae:hasSolverVersion a owl:DatatypeProperty ;
    rdfs:domain cae:SimulationRun ;
    rdfs:range xsd:string ;
    rdfs:label "solver version" .

cae:hasMeshDensity a owl:DatatypeProperty ;
    rdfs:domain cae:SimulationRun ;
    rdfs:range xsd:decimal ;
    rdfs:label "characteristic mesh element size" .

cae:hasLoadValue a owl:DatatypeProperty ;
    rdfs:domain cae:BoundaryCondition ;
    rdfs:range xsd:decimal ;
    rdfs:label "load magnitude" .

cae:hasLoadDirection a owl:DatatypeProperty ;
    rdfs:domain cae:BoundaryCondition ;
    rdfs:range xsd:string ;
    rdfs:label "load direction vector" .

cae:hasMaxStress a owl:DatatypeProperty ;
    rdfs:domain cae:SimulationResult ;
    rdfs:range xsd:decimal ;
    rdfs:label "maximum von Mises stress in Pa" .

cae:hasMaxDisplacement a owl:DatatypeProperty ;
    rdfs:domain cae:SimulationResult ;
    rdfs:range xsd:decimal ;
    rdfs:label "maximum displacement in meters" .

cae:hasSafetyFactor a owl:DatatypeProperty ;
    rdfs:domain cae:SimulationResult ;
    rdfs:range xsd:decimal ;
    rdfs:label "minimum safety factor" .

cae:nodeX a owl:DatatypeProperty ;
    rdfs:domain cae:SimulationNode ;
    rdfs:range xsd:decimal ;
    rdfs:label "node X coordinate in meters" .

cae:nodeY a owl:DatatypeProperty ;
    rdfs:domain cae:SimulationNode ;
    rdfs:range xsd:decimal ;
    rdfs:label "node Y coordinate in meters" .

cae:nodeZ a owl:DatatypeProperty ;
    rdfs:domain cae:SimulationNode ;
    rdfs:range xsd:decimal ;
    rdfs:label "node Z coordinate in meters" .

cae:nodeStress a owl:DatatypeProperty ;
    rdfs:domain cae:SimulationNode ;
    rdfs:range xsd:decimal ;
    rdfs:label "node von Mises stress in Pa" .

cae:nodeDisplacement a owl:DatatypeProperty ;
    rdfs:domain cae:SimulationNode ;
    rdfs:range xsd:decimal ;
    rdfs:label "node displacement magnitude in meters" .

plm:hasYieldStrength a owl:DatatypeProperty ;
    rdfs:domain plm:Material ;
    rdfs:range xsd:decimal ;
    rdfs:label "yield strength in Pa" .

plm:hasDensity a owl:DatatypeProperty ;
    rdfs:domain plm:Material ;
    rdfs:range xsd:decimal ;
    rdfs:label "density in kg/m³" .

plm:hasYoungsModulus a owl:DatatypeProperty ;
    rdfs:domain plm:Material ;
    rdfs:range xsd:decimal ;
    rdfs:label "Young's modulus in Pa" .

plm:hasPoissonRatio a owl:DatatypeProperty ;
    rdfs:domain plm:Material ;
    rdfs:range xsd:decimal ;
    rdfs:label "Poisson's ratio (dimensionless)" .
