{
  "graph": {
    "metadata": {
      "name": "Offshore Wind Turbine 15MW System Model",
      "version": "1.0",
      "standard": "IEC 61400-1 Ed.4, IEC 61400-3-1, DNV-ST-0438, GL 2012",
      "created": "2026-05-31"
    },
    "nodes": [
      {"id": "OWT-001", "kind": "Block", "attributes": {"name": {"Text": "Offshore Wind Turbine 15MW System"}, "description": {"Text": "15 MW direct-drive PMSG offshore HAWT, 240m rotor, 150m hub height, IEC Class I-S, 25-yr design life"}}},
      {"id": "ROTOR-001", "kind": "Block", "attributes": {"name": {"Text": "Rotor Assembly"}, "description": {"Text": "3-blade HAWT rotor: 120m LW blades, hub casting, pitch drives. Rated at 7.56 RPM, 15.7 MN·m torque"}}},
      {"id": "BLADE-001", "kind": "Component", "attributes": {"name": {"Text": "Blade 1 (120m LW)"}, "description": {"Text": "120m length, CFRP/GRP spar cap, aerodynamic shells, Cp_max 0.489 at lambda=9, 65t mass per blade"}}},
      {"id": "BLADE-002", "kind": "Component", "attributes": {"name": {"Text": "Blade 2 (120m LW)"}, "description": {"Text": "120m CFRP/GRP blade, identical to Blade 1, 120 deg apart"}}},
      {"id": "BLADE-003", "kind": "Component", "attributes": {"name": {"Text": "Blade 3 (120m LW)"}, "description": {"Text": "120m CFRP/GRP blade, 240 deg azimuth offset"}}},
      {"id": "PITCH-001", "kind": "Component", "attributes": {"name": {"Text": "Pitch Drive System (3x)"}, "description": {"Text": "Electric pitch drive, 250 kNm per blade, ±8 deg/s rate, individual and collective pitch control"}}},
      {"id": "HUB-001", "kind": "Component", "attributes": {"name": {"Text": "Hub Casting"}, "description": {"Text": "EN-GJS-400-18-LT casting, 47t, 3x 4520mm OD pitch bearing seats, main shaft flange 2800mm dia"}}},
      {"id": "DRIVETRAIN-001", "kind": "Block", "attributes": {"name": {"Text": "Direct-Drive Drivetrain"}, "description": {"Text": "Main bearing, main shaft, direct-drive PMSG. No gearbox. Rated torque 15.7 MN·m at 7.56 RPM"}}},
      {"id": "MAINBEAR-001", "kind": "Component", "attributes": {"name": {"Text": "Main Bearing Assembly"}, "description": {"Text": "Double-row tapered roller bearing, 3.5m bore, L10h >200,000 hr, moment capacity 300 MN·m"}}},
      {"id": "SHAFT-001", "kind": "Component", "attributes": {"name": {"Text": "Main Shaft"}, "description": {"Text": "Hollow forged 42CrMo4 shaft, OD=2200mm, t=120mm, L=4.5m, connects hub to PMSG rotor"}}},
      {"id": "PMSG-001", "kind": "Component", "attributes": {"name": {"Text": "Permanent Magnet Synchronous Generator"}, "description": {"Text": "Direct-drive PMSG, P_rated=15 MW, 160-pole, 6.28 Hz electrical at rated, 96% efficiency, 350t"}}},
      {"id": "PCONV-001", "kind": "Block", "attributes": {"name": {"Text": "Power Conversion System"}, "description": {"Text": "Full-power back-to-back IGBT converter: MSC + GSC, AC/DC/AC, grid code compliance FRT"}}},
      {"id": "MSC-001", "kind": "Component", "attributes": {"name": {"Text": "Machine-Side Converter (MSC)"}, "description": {"Text": "IGBT converter, 18 MVA, MPPT torque control, variable speed 5-7.56 RPM, DC link 1150 V"}}},
      {"id": "GSC-001", "kind": "Component", "attributes": {"name": {"Text": "Grid-Side Converter (GSC)"}, "description": {"Text": "IGBT GSC, 18 MVA, P/Q control, FRT to 0% voltage 150ms, PF range 0.95 lead/lag, 690V AC out"}}},
      {"id": "TRANS-001", "kind": "Component", "attributes": {"name": {"Text": "Step-Up Transformer (690V/33kV)"}, "description": {"Text": "Dry-type transformer, 18 MVA, 690V/33kV, dYn11, offshore rated, salt-spray protected, IEC 60076"}}},
      {"id": "YAW-001", "kind": "Block", "attributes": {"name": {"Text": "Yaw System"}, "description": {"Text": "Active yaw: 8x electric yaw drives, yaw bearing 5.2m dia, ±0.3 deg/s, wind-vane + LiDAR reference"}}},
      {"id": "YAW-BEAR", "kind": "Component", "attributes": {"name": {"Text": "Yaw Bearing (Slewing Ring)"}, "description": {"Text": "Four-point contact slewing ring, OD=5200mm, internal gear, 25-yr fatigue life DNV-ST-0126"}}},
      {"id": "YAW-DRIVE", "kind": "Component", "attributes": {"name": {"Text": "Yaw Drive Units (8x)"}, "description": {"Text": "8x electric yaw motors, 45 kNm each, worm gearbox, yaw brake integrated, pinion-on-ring"}}},
      {"id": "NACELLE-001", "kind": "Component", "attributes": {"name": {"Text": "Nacelle Structure and Bedplate"}, "description": {"Text": "Welded steel bedplate, 22m x 9m, crane access, main shaft support, nacelle cover GRP 350t"}}},
      {"id": "CTRL-001", "kind": "Block", "attributes": {"name": {"Text": "Turbine Control System (TCS)"}, "description": {"Text": "VSVP controller: collective pitch, IPC, torque, yaw, FATD, grid supervision. IEC 61400-1 compliance"}}},
      {"id": "CTRL-PITCH", "kind": "Component", "attributes": {"name": {"Text": "Collective Pitch Controller"}, "description": {"Text": "PID with gain scheduling, Kp=0.006275 rad/(rad/s), region 2/3 transition, feather on emergency"}}},
      {"id": "CTRL-IPC", "kind": "Component", "attributes": {"name": {"Text": "Individual Pitch Control (IPC)"}, "description": {"Text": "MBC3 transform, 1P/2P tilt-yaw load alleviation, >15% DEL reduction on blade root and tower"}}},
      {"id": "CTRL-FATD", "kind": "Component", "attributes": {"name": {"Text": "Tower Fore-Aft Damping (FATD)"}, "description": {"Text": "Tower 1st FA mode damping via generator torque feedback, +5 dB at 0.198 Hz, accelerometer feedback"}}},
      {"id": "SCADA-001", "kind": "Block", "attributes": {"name": {"Text": "SCADA and Condition Monitoring"}, "description": {"Text": "Turbine SCADA: data acquisition, remote control, CMMS integration, OPC-UA server, 10ms scan rate"}}},
      {"id": "CMS-001", "kind": "Component", "attributes": {"name": {"Text": "Condition Monitoring System"}, "description": {"Text": "Vibration-based CMS: main bearing, gearbox (N/A direct drive), generator, tower, strain gauges"}}},
      {"id": "FOUND-001", "kind": "Block", "attributes": {"name": {"Text": "Foundation and Support Structure"}, "description": {"Text": "Monopile or jacket foundation, 40-60m water depth, grouted transition piece, corrosion protection"}}},
      {"id": "MONOPILE-001", "kind": "Component", "attributes": {"name": {"Text": "Monopile Foundation"}, "description": {"Text": "S355NL steel monopile, OD=10.5m, t=90mm, 80m driven length, rated for 25-yr fatigue + 50-yr extreme"}}},
      {"id": "TP-001", "kind": "Component", "attributes": {"name": {"Text": "Transition Piece"}, "description": {"Text": "Grouted transition piece, boat landing, J-tubes for cables, anode system, platform for access"}}},
      {"id": "TOWER-001", "kind": "Component", "attributes": {"name": {"Text": "Tower (3 sections)"}, "description": {"Text": "Tubular steel tower, 150m height, 3 sections, base dia 10m top dia 6m, S355 J2G3, 600t"}}},
      {"id": "ARRAY-001", "kind": "Component", "attributes": {"name": {"Text": "Array Cable (33kV)"}, "description": {"Text": "33kV XLPE submarine cable, 3-core, 95 sq mm Cu, J-tube entry, 500m inter-turbine spacing"}}},
      {"id": "SIG-WIND", "kind": "Signal", "attributes": {"name": {"Text": "Wind Speed/Direction Signal"}, "description": {"Text": "10-min avg + 1s gust from 3x cup anemometers + LiDAR, IEC 61400-12 calibration"}}},
      {"id": "SIG-POWER", "kind": "Signal", "attributes": {"name": {"Text": "Active Power Output Signal"}, "description": {"Text": "Measured 3-phase power at GSC terminals, 10ms resolution, power curve validation, SCADA archived"}}},
      {"id": "FUN-POWER", "kind": "Function", "attributes": {"name": {"Text": "Power Extraction (MPPT)"}, "description": {"Text": "Track optimal tip-speed ratio lambda=9 below rated; limit to 15 MW above rated via pitch control"}}},
      {"id": "FUN-LOAD", "kind": "Function", "attributes": {"name": {"Text": "Fatigue Load Reduction"}, "description": {"Text": "Reduce blade root flapwise DEL by >= 15% via IPC; reduce tower FA moment via FATD"}}},
      {"id": "REQ-001", "kind": "Requirement", "attributes": {"name": {"Text": "Rated Power Tracking"}, "description": {"Text": "Turbine shall track rated power 15 MW within ±2% for wind speeds v_rated to v_cut_out"}}},
      {"id": "REQ-002", "kind": "Requirement", "attributes": {"name": {"Text": "Pitch Actuator Bandwidth"}, "description": {"Text": "Blade pitch actuation system bandwidth shall be >= 1.0 rad/s at rated operating point"}}},
      {"id": "REQ-003", "kind": "Requirement", "attributes": {"name": {"Text": "Fatigue DEL Reduction"}, "description": {"Text": "IPC shall reduce blade root flapwise damage equivalent load by >= 15% versus CPC-only baseline"}}},
      {"id": "REQ-004", "kind": "Requirement", "attributes": {"name": {"Text": "Tower FA Damping"}, "description": {"Text": "FATD controller shall add >= 5 dB of damping at the tower 1st fore-aft natural frequency"}}},
      {"id": "REQ-005", "kind": "Requirement", "attributes": {"name": {"Text": "Emergency Stop Time"}, "description": {"Text": "From emergency stop command to rotor speed < 1 RPM shall be achieved within <= 60 seconds"}}},
      {"id": "REQ-006", "kind": "Requirement", "attributes": {"name": {"Text": "Grid Code Compliance FRT"}, "description": {"Text": "Turbine shall ride through voltage dips to 0% Un for 150 ms and recover to 90% Un within 1500 ms"}}},
      {"id": "REQ-007", "kind": "Requirement", "attributes": {"name": {"Text": "Foundation Design Life"}, "description": {"Text": "Foundation structure shall meet IEC 61400-3 fatigue and extreme load requirements for 25-year design life"}}},
      {"id": "REQ-008", "kind": "Requirement", "attributes": {"name": {"Text": "Availability"}, "description": {"Text": "Technical availability shall be >= 97% averaged over any rolling 12-month offshore operating period"}}},
      {"id": "REQ-009", "kind": "Requirement", "attributes": {"name": {"Text": "Generator Efficiency"}, "description": {"Text": "PMSG shall achieve >= 96% efficiency at rated power and >= 94% at 25% rated power"}}},
      {"id": "REQ-010", "kind": "Requirement", "attributes": {"name": {"Text": "Condition Monitoring"}, "description": {"Text": "CMS shall detect main bearing defect frequency signatures with >= 30 days advance warning before failure"}}}
    ],
