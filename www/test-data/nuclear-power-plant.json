{
  "graph": {
    "metadata": {
      "name": "Nuclear Power Plant - AP1000 PWR System Model",
      "version": "1.2",
      "standard": "IEEE Std 603, 10 CFR 50",
      "created": "2026-05-31"
    },
    "nodes": [
      {"id": "NPP-001", "kind": "Block", "attributes": {"name": {"Text": "AP1000 Nuclear Power Plant"}, "description": {"Text": "1117 MWe Pressurized Water Reactor power plant, passive safety systems, 60-year design life"}}},
      {"id": "RCS-001", "kind": "Block", "attributes": {"name": {"Text": "Reactor Coolant System"}, "description": {"Text": "Primary loop: reactor, 2 hot legs, 2 cold legs, 2 SGs, 4 RCPs, pressurizer. P=15.51 MPa, Tmax=325°C"}}},
      {"id": "RXR-001", "kind": "Component", "attributes": {"name": {"Text": "Reactor Core and Pressure Vessel"}, "description": {"Text": "157 fuel assemblies, 264 rods/FA, UO2 4.5% enriched, 3411 MWth rated thermal power"}}},
      {"id": "RCP-001", "kind": "Component", "attributes": {"name": {"Text": "Reactor Coolant Pump 1A"}, "description": {"Text": "Canned motor RCP, 7200 m³/h, 80m head, 7000 kW, no seals (AP1000 passive)"}}},
      {"id": "RCP-002", "kind": "Component", "attributes": {"name": {"Text": "Reactor Coolant Pump 1B"}, "description": {"Text": "Canned motor RCP, 7200 m³/h, 80m head, 7000 kW"}}},
      {"id": "RCP-003", "kind": "Component", "attributes": {"name": {"Text": "Reactor Coolant Pump 2A"}, "description": {"Text": "Canned motor RCP, 7200 m³/h, 80m head, 7000 kW"}}},
      {"id": "RCP-004", "kind": "Component", "attributes": {"name": {"Text": "Reactor Coolant Pump 2B"}, "description": {"Text": "Canned motor RCP, 7200 m³/h, 80m head, 7000 kW"}}},
      {"id": "PZR-001", "kind": "Component", "attributes": {"name": {"Text": "Pressurizer"}, "description": {"Text": "Volume 59.5 m³, 6 heater banks 1800 kW total, 4 spray nozzles, PORV, setpoint 15.51 MPa"}}},
      {"id": "SG-001", "kind": "Component", "attributes": {"name": {"Text": "Steam Generator 1"}, "description": {"Text": "Vertical U-tube SG, 10,025 tubes Inconel 690, primary/secondary heat exchange, P_sec=6.89 MPa"}}},
      {"id": "SG-002", "kind": "Component", "attributes": {"name": {"Text": "Steam Generator 2"}, "description": {"Text": "Vertical U-tube SG, 10,025 tubes Inconel 690"}}},
      {"id": "SEC-001", "kind": "Block", "attributes": {"name": {"Text": "Secondary (Steam/Power) System"}, "description": {"Text": "Steam supply, HP/LP turbine, condenser, feedwater, generator. Rankine cycle, eta~34%"}}},
      {"id": "HPT-001", "kind": "Component", "attributes": {"name": {"Text": "HP Turbine"}, "description": {"Text": "Single-flow HP turbine, inlet P=6.62 MPa T=275°C, extraction for moisture separator reheater"}}},
      {"id": "LPT-001", "kind": "Component", "attributes": {"name": {"Text": "LP Turbine A"}, "description": {"Text": "Double-flow LP turbine, 52-inch last stage blade, exhaust P=6.8 kPa"}}},
      {"id": "LPT-002", "kind": "Component", "attributes": {"name": {"Text": "LP Turbine B"}, "description": {"Text": "Double-flow LP turbine, 52-inch last stage blade, exhaust P=6.8 kPa"}}},
      {"id": "GEN-001", "kind": "Component", "attributes": {"name": {"Text": "Main Turbine Generator"}, "description": {"Text": "1200 MVA, 24 kV, 60 Hz, hydrogen cooled, direct-drive, step-up transformer 24kV/345kV"}}},
      {"id": "COND-001", "kind": "Component", "attributes": {"name": {"Text": "Main Condenser"}, "description": {"Text": "Surface condenser, titanium tubes, 2-pass, 2750 MWt rejected, circulating water 2x14m³/s"}}},
      {"id": "ECCS-001", "kind": "Block", "attributes": {"name": {"Text": "Emergency Core Cooling System"}, "description": {"Text": "AP1000 passive ECCS: core makeup tanks, accumulators, IRWST. No AC pumps required 72 hr"}}},
      {"id": "CMT-001", "kind": "Component", "attributes": {"name": {"Text": "Core Makeup Tank 1"}, "description": {"Text": "CMT volume 70.8 m³, borated water 4000 ppm, passive injection on RCS depressurisation"}}},
      {"id": "CMT-002", "kind": "Component", "attributes": {"name": {"Text": "Core Makeup Tank 2"}, "description": {"Text": "CMT volume 70.8 m³, borated water 4000 ppm"}}},
      {"id": "ACC-001", "kind": "Component", "attributes": {"name": {"Text": "Accumulator A"}, "description": {"Text": "Passive accumulator 56.6 m³, N2 pressurized 4.8 MPa, injects below 4.8 MPa RCS pressure"}}},
      {"id": "ACC-002", "kind": "Component", "attributes": {"name": {"Text": "Accumulator B"}, "description": {"Text": "Passive accumulator 56.6 m³, N2 pressurized 4.8 MPa"}}},
      {"id": "CONT-001", "kind": "Block", "attributes": {"name": {"Text": "Containment Structure"}, "description": {"Text": "Steel containment vessel ID=39.6m H=65.6m, passive cooling by natural air convection + water film"}}},
      {"id": "PCS-001", "kind": "Component", "attributes": {"name": {"Text": "Passive Containment Cooling System"}, "description": {"Text": "PCCS water tank 2.5 MWt 72-hr capacity, gravity drain, air baffles, no pumps or AC power"}}},
      {"id": "ICS-001", "kind": "Block", "attributes": {"name": {"Text": "Instrumentation and Control System"}, "description": {"Text": "Westinghouse BEACON/SETPOINT, Advant OCS DCS, QA Div I-IV safety class, IEEE Std 603"}}},
      {"id": "RPS-001", "kind": "Component", "attributes": {"name": {"Text": "Reactor Protection System"}, "description": {"Text": "2-of-4 logic, 4 divisions, 25ms trip response, scram signals: overpower, DNBR, pressure, Tavg"}}},
      {"id": "RCMS-001", "kind": "Component", "attributes": {"name": {"Text": "Rod Control and Monitoring System"}, "description": {"Text": "CEA drive mechanism, 4 control banks, 228 steps/bank, 8 steps/min normal, full scram <2.2 s"}}},
      {"id": "EPMS-001", "kind": "Component", "attributes": {"name": {"Text": "Electrical Power Management System"}, "description": {"Text": "4160V / 480V AC distribution, 4 onsite diesel generators 9.4 MW each, 250V DC batteries 2h"}}},
      {"id": "SIG-PWR", "kind": "Signal", "attributes": {"name": {"Text": "Thermal Power Signal"}, "description": {"Text": "Calibrated neutron flux (ex-core) + calorimetric power signal, range 0-120% rated"}}},
      {"id": "SIG-TEMP", "kind": "Signal", "attributes": {"name": {"Text": "Coolant Temperature Signal"}, "description": {"Text": "RTD Tavg from 4 hot/cold legs, ±0.5°C accuracy, 100ms scan"}}},
      {"id": "SIG-PRES", "kind": "Signal", "attributes": {"name": {"Text": "RCS Pressure Signal"}, "description": {"Text": "Dual pressure transmitters per measurement point, ±0.1% span, 15.51 MPa nominal"}}},
      {"id": "FUN-HEAT", "kind": "Function", "attributes": {"name": {"Text": "Thermal Energy Transfer"}, "description": {"Text": "Transfer 3411 MWth from fuel to primary coolant, maintain coolant margin to nucleate boiling"}}},
      {"id": "FUN-PROT", "kind": "Function", "attributes": {"name": {"Text": "Reactor Trip and Safety Function"}, "description": {"Text": "Initiate automatic scram within 25ms of trip condition; insert all CEAs, achieve sub-critical state"}}},
      {"id": "REQ-001", "kind": "Requirement", "attributes": {"name": {"Text": "Rated Thermal Power"}, "description": {"Text": "The reactor shall deliver 3411 MWth rated thermal power at 100% power operation"}}},
      {"id": "REQ-002", "kind": "Requirement", "attributes": {"name": {"Text": "DNBR Safety Limit"}, "description": {"Text": "Departure from nucleate boiling ratio shall not fall below 1.30 under any normal or AOO transient"}}},
      {"id": "REQ-003", "kind": "Requirement", "attributes": {"name": {"Text": "Scram Response Time"}, "description": {"Text": "Control rod full insertion shall be achieved within 2.2 seconds of trip signal per GDC-17"}}},
      {"id": "REQ-004", "kind": "Requirement", "attributes": {"name": {"Text": "Passive Safety 72-Hour"}, "description": {"Text": "Passive safety systems shall provide core cooling and containment integrity for 72 hours without AC power or operator action"}}},
      {"id": "REQ-005", "kind": "Requirement", "attributes": {"name": {"Text": "Coolant Pressure Boundary"}, "description": {"Text": "Primary coolant pressure boundary shall withstand 17.13 MPa design pressure per ASME Sec III"}}},
      {"id": "REQ-006", "kind": "Requirement", "attributes": {"name": {"Text": "Containment Design Pressure"}, "description": {"Text": "Steel containment vessel shall withstand 0.41 MPa internal design pressure per 10 CFR 50 Appendix J"}}},
      {"id": "REQ-007", "kind": "Requirement", "attributes": {"name": {"Text": "Turbine Generator Output"}, "description": {"Text": "The plant shall produce a minimum of 1117 MWe net electrical output at rated thermal power"}}},
      {"id": "REQ-008", "kind": "Requirement", "attributes": {"name": {"Text": "Control Power Range"}, "description": {"Text": "Load follow capability 100%-50%-100% rated power within 30 minutes using CEA control only"}}},
      {"id": "REQ-009", "kind": "Requirement", "attributes": {"name": {"Text": "Fuel Centerline Temperature"}, "description": {"Text": "Peak fuel centerline temperature shall not exceed 1650°C under any AOO condition"}}},
      {"id": "REQ-010", "kind": "Requirement", "attributes": {"name": {"Text": "Design Life"}, "description": {"Text": "The plant shall be designed for a 60-year operating life with licence renewal provision to 80 years"}}}
    ],
