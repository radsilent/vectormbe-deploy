        "unit": "dimensionless",
        "sampling_rate_hz": "5",
        "message_id": "ADCS-05"
      }
    },
    {
      "id": "s-fault-flag",
      "kind": "Signal",
      "attributes": {
        "name": "FaultStatusFlags",
        "description": "Bitfield indicating FDI status for each sensor and actuator",
        "unit": "bitfield",
        "sampling_rate_hz": "1",
        "message_id": "ADCS-06"
      }
    },
    {
      "id": "i-adcs-bus",
      "kind": "Interface",
      "attributes": {
        "name": "ADCS-CAN-Bus",
        "protocol": "CAN-FD",
        "baudrate": "2000000",
        "description": "Internal ADCS controller area network"
      }
    },
    {
      "id": "i-obc-link",
      "kind": "Interface",
      "attributes": {
        "name": "ADCS-OBC-SpaceWire",
        "protocol": "SpaceWire",
        "baudrate": "200000000",
        "description": "High-speed link to onboard computer for telemetry and commands"
      }
    },
    {
      "id": "req-pointing",
      "kind": "Requirement",
      "attributes": {
        "name": "REQ-ADCS-001",
        "description": "ADCS shall maintain nadir pointing accuracy of 0.01° (3σ) during nominal imaging operations",
        "priority": "Critical",
        "verification_method": "Test"
      }
    },
    {
      "id": "req-slew",
      "kind": "Requirement",
      "attributes": {
        "name": "REQ-ADCS-002",
        "description": "ADCS shall complete 180° slew maneuver within 60 seconds using reaction wheels",
        "priority": "High",
        "verification_method": "Test"
      }
    },
    {
      "id": "req-fault",
      "kind": "Requirement",
      "attributes": {
        "name": "REQ-ADCS-003",
        "description": "ADCS shall detect and isolate single sensor/actuator faults within 500ms",
        "priority": "Critical",
        "verification_method": "Analysis and Test"
      }
    }
