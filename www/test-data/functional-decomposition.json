        "sampling_rate_hz": "50",
        "message_id": "ADCS-01"
      }
    },
    {
      "id": "s-angular-rate",
      "kind": "Signal",
      "attributes": {
        "name": "AngularRateVector",
        "description": "Body-frame angular rates from gyro triad",
        "unit": "deg/s",
        "sampling_rate_hz": "100",
        "message_id": "ADCS-02"
      }
    },
    {
      "id": "s-wheel-speed",
      "kind": "Signal",
      "attributes": {
        "name": "WheelSpeeds",
        "description": "Reaction wheel tachometer readings for all 4 wheels",
        "unit": "rpm",
        "sampling_rate_hz": "100",
        "message_id": "ADCS-03"
      }
    },
    {
      "id": "s-torque-cmd",
      "kind": "Signal",
      "attributes": {
        "name": "TorqueCommand",
        "description": "Actuator torque commands sent to reaction wheels and magnetorquers",
        "unit": "Nm",
        "sampling_rate_hz": "50",
        "message_id": "ADCS-04"
      }
    },
    {
      "id": "s-star-vectors",
      "kind": "Signal",
      "attributes": {
        "name": "StarUnitVectors",
