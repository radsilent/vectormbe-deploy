{
  "_comment": "VectorOWL functional decomposition demo — Satellite Attitude Determination and Control System (ADCS)",
  "nodes": [
    {
      "id": "f-adcs",
      "kind": "Function",
      "attributes": {
        "name": "AttitudeDeterminationAndControl",
        "description": "Maintain satellite pointing accuracy within 0.01° across all mission phases",
        "safety_level": "ASIL-D",
        "fidelity": "system"
      }
    },
    {
      "id": "f-determination",
      "kind": "Function",
      "attributes": {
        "name": "AttitudeDetermination",
        "description": "Compute current spacecraft attitude from sensor fusion",
        "safety_level": "ASIL-D",
        "fidelity": "subsystem"
      }
    },
    {
      "id": "f-control",
      "kind": "Function",
      "attributes": {
        "name": "AttitudeControl",
        "description": "Generate actuator commands to achieve target attitude",
        "safety_level": "ASIL-D",
        "fidelity": "subsystem"
      }
    },
    {
      "id": "f-sensor-fusion",
      "kind": "Function",
      "attributes": {
        "name": "SensorFusion",
        "description": "Combine star tracker, gyro, and sun sensor measurements via EKF",
        "safety_level": "ASIL-C",
        "fidelity": "component"
      }
    },
    {
      "id": "f-star-ident",
      "kind": "Function",
      "attributes": {
        "name": "StarIdentification",
        "description": "Match observed star patterns against onboard catalog",
        "safety_level": "ASIL-C",
        "fidelity": "component"
      }
    },
    {
      "id": "f-gyro-prop",
      "kind": "Function",
      "attributes": {
        "name": "GyroPropagation",
        "description": "Propagate attitude quaternion from gyro rate measurements",
        "safety_level": "ASIL-B",
        "fidelity": "component"
      }
    },
    {
      "id": "f-momentum-mgmt",
      "kind": "Function",
      "attributes": {
        "name": "MomentumManagement",
        "description": "Desaturate reaction wheel momentum using magnetorquers",
        "safety_level": "ASIL-C",
        "fidelity": "component"
      }
    },
    {
      "id": "f-pointing-control",
      "kind": "Function",
      "attributes": {
        "name": "PointingControl",
        "description": "Closed-loop PID control for nadir/solar/inertial pointing modes",
        "safety_level": "ASIL-D",
        "fidelity": "component"
      }
    },
    {
      "id": "f-slew-maneuver",
      "kind": "Function",
      "attributes": {
        "name": "SlewManeuver",
        "description": "Execute eigenaxis slew between attitude targets within 60s",
        "safety_level": "ASIL-C",
        "fidelity": "component"
      }
    },
    {
      "id": "f-fault-detection",
      "kind": "Function",
      "attributes": {
        "name": "FaultDetectionAndIsolation",
        "description": "Detect sensor or actuator faults and reconfigure control law",
        "safety_level": "ASIL-D",
        "fidelity": "component"
      }
    },
    {
      "id": "f-mode-transition",
      "kind": "Function",
      "attributes": {
        "name": "ModeTransition",
        "description": "Safe state machine transitions between detumble, sun-acquisition, nadir, and inertial modes",
        "safety_level": "ASIL-D",
        "fidelity": "component"
      }
    },
    {
      "id": "c-adcs-computer",
      "kind": "Component",
      "attributes": {
        "name": "ADCS-Computer",
        "description": "Leon3FT fault-tolerant processor running RTEMS",
        "part_number": "ADCS-CPU-2026",
        "software_version": "4.2.1"
      }
    },
    {
      "id": "c-star-tracker",
      "kind": "Component",
      "attributes": {
        "name": "StarTracker",
        "description": "CCD-based star tracker with 8° FOV and 5 arcsec accuracy",
        "part_number": "ST-500-HD"
      }
    },
    {
      "id": "c-gyro-assembly",
      "kind": "Component",
      "attributes": {
        "name": "GyroAssembly",
        "description": "3-axis fiber optic gyro package with 0.001°/hr bias stability",
        "part_number": "FOG-3X-2026"
      }
    },
    {
      "id": "c-reaction-wheel",
      "kind": "Component",
      "attributes": {
        "name": "ReactionWheelAssembly",
        "description": "4-wheel pyramid configuration, 0.5 Nms momentum capacity each",
        "part_number": "RW-4P-2026"
      }
    },
    {
      "id": "c-magnetorquer",
      "kind": "Component",
      "attributes": {
        "name": "MagnetorquerCoils",
        "description": "3-axis magnetic torque rods for momentum dumping",
        "part_number": "MT-30AM2"
      }
    },
    {
      "id": "c-sun-sensor",
      "kind": "Component",
      "attributes": {
        "name": "SunSensor",
        "description": "Analog coarse sun sensor for initial acquisition and safe mode",
        "part_number": "CSS-6F-2026"
      }
    },
    {
      "id": "s-quaternion",
      "kind": "Signal",
      "attributes": {
        "name": "AttitudeQuaternion",
        "description": "Estimated attitude as normalized quaternion [q0,q1,q2,q3]",
