ISO-10303-21;
HEADER;
FILE_DESCRIPTION(('PWR Reactor Pressure Vessel Assembly'
  'AP214 Mechanical Design - Nuclear Island'
  'System: AP1000 Westinghouse PWR'
  'Assembly: Reactor Pressure Vessel (RPV) - 12 Components'
  'Standard: ASME Sec III Div 1 Class 1, RCC-M B-Series'),
  '2;1');
FILE_NAME('/nuclear/RPV_Assembly_AP1000.step',
  '2026-05-31T08:00:00',
  ('MBSE Design Team','Nuclear Systems Dept'),
  ('VectorMBE CAD Export'),
  'VectorMBE STEP AP214 Exporter v2.4',
  'Nuclear Pressure Boundary Design Rev C',
  'CONTROLLED DOCUMENT - PROPRIETARY');
FILE_SCHEMA(('AUTOMOTIVE_DESIGN { 1 0 10303 214 3 1 1 1 }'));
ENDSEC;

DATA;

/* ---- APPLICATION CONTEXT ---- */
#1 = APPLICATION_CONTEXT('automotive design');
#2 = APPLICATION_PROTOCOL_DEFINITION('international standard',
     'automotive_design',2000,#1);
#3 = PRODUCT_CONTEXT('',#1,'mechanical');

/* ---- PRODUCT: RPV ASSEMBLY ---- */
#10 = PRODUCT('RPV-001','Reactor Pressure Vessel Assembly',
     'AP1000 RPV - OD 4420mm, H 12600mm, SA-508 Gr.3',(#3));
#11 = PRODUCT_DEFINITION_FORMATION('A','Initial Design Release',#10);
#12 = PRODUCT_DEFINITION(#11,'RPV_Assembly_Body',#13);
#13 = PRODUCT_DEFINITION_CONTEXT('part definition',#1,'design');

/* ---- PRODUCT: RPV HEAD ---- */
#20 = PRODUCT('RPV-HEAD-001','RPV Upper Head',
     'Hemispherical head, SA-508 Gr.3 Cl.1, t=152mm, ID=4040mm',(#3));
#21 = PRODUCT_DEFINITION_FORMATION('A','Release',#20);
#22 = PRODUCT_DEFINITION(#21,'RPV_Head_Body',#13);

/* ---- PRODUCT: VESSEL SHELL (UPPER) ---- */
#30 = PRODUCT('RPV-SHELL-U','RPV Upper Shell Course',
     'Cylindrical shell, SA-533 Gr.B Cl.1, t=202mm, ID=4040mm, H=2400mm',(#3));
#31 = PRODUCT_DEFINITION_FORMATION('A','Release',#30);
#32 = PRODUCT_DEFINITION(#31,'RPV_Shell_Upper_Body',#13);

/* ---- PRODUCT: VESSEL SHELL (LOWER) ---- */
#40 = PRODUCT('RPV-SHELL-L','RPV Lower Shell Course',
     'Cylindrical shell, SA-533 Gr.B Cl.1, t=216mm, ID=4040mm, H=2600mm',(#3));
#41 = PRODUCT_DEFINITION_FORMATION('A','Release',#40);
#42 = PRODUCT_DEFINITION(#41,'RPV_Shell_Lower_Body',#13);

/* ---- PRODUCT: NOZZLE RING / BELT ---- */
#50 = PRODUCT('RPV-NZ-RING','RPV Nozzle Belt Ring',
     'Forged nozzle belt, SA-508 Gr.3, 4x300mm inlet + 4x355mm outlet nozzles',(#3));
#51 = PRODUCT_DEFINITION_FORMATION('A','Release',#50);
#52 = PRODUCT_DEFINITION(#51,'RPV_Nozzle_Ring_Body',#13);

/* ---- PRODUCT: BOTTOM HEAD ---- */
#60 = PRODUCT('RPV-BOT-001','RPV Bottom Head',
     'Hemispherical head with 69x CEDM penetrations, SA-508 Gr.3, t=140mm',(#3));
#61 = PRODUCT_DEFINITION_FORMATION('A','Release',#60);
#62 = PRODUCT_DEFINITION(#61,'RPV_Bottom_Head_Body',#13);

/* ---- PRODUCT: CORE BARREL ---- */
#70 = PRODUCT('RPV-CB-001','Core Support Barrel',
     'Cylindrical barrel, type 304L SS, OD=3937mm, t=44mm, H=6720mm',(#3));
#71 = PRODUCT_DEFINITION_FORMATION('A','Release',#70);
#72 = PRODUCT_DEFINITION(#71,'Core_Barrel_Body',#13);

/* ---- PRODUCT: UPPER INTERNALS ---- */
#80 = PRODUCT('RPV-INT-U','Upper Core Internals Placeholder',
     'Upper support plate, guide tubes, hold-down spring, type 316L SS',(#3));
#81 = PRODUCT_DEFINITION_FORMATION('A','Placeholder',#80);
#82 = PRODUCT_DEFINITION(#81,'Upper_Internals_Body',#13);

/* ---- NEXT ASSEMBLY USAGE OCCURRENCES ---- */
/* Head -> Assembly */
#100 = NEXT_ASSEMBLY_USAGE_OCCURRENCE('RPV-HEAD-QTY1','',#12,#22,$,$);
/* Upper Shell -> Assembly */
#101 = NEXT_ASSEMBLY_USAGE_OCCURRENCE('RPV-SHELL-U-QTY1','',#12,#32,$,$);
/* Lower Shell -> Assembly */
#102 = NEXT_ASSEMBLY_USAGE_OCCURRENCE('RPV-SHELL-L-QTY1','',#12,#42,$,$);
/* Nozzle Ring -> Assembly */
#103 = NEXT_ASSEMBLY_USAGE_OCCURRENCE('RPV-NZ-QTY1','',#12,#52,$,$);
/* Bottom Head -> Assembly */
#104 = NEXT_ASSEMBLY_USAGE_OCCURRENCE('RPV-BOT-QTY1','',#12,#62,$,$);
/* Core Barrel -> Assembly (internal) */
#105 = NEXT_ASSEMBLY_USAGE_OCCURRENCE('RPV-CB-QTY1','RPV internal',#12,#72,$,$);
/* Upper Internals -> Assembly */
#106 = NEXT_ASSEMBLY_USAGE_OCCURRENCE('RPV-INT-U-QTY1','',#12,#82,$,$);

/* ---- PRODUCT CATEGORIES ---- */
#200 = PRODUCT_CATEGORY('assembly','top-level RPV assembly');
#201 = PRODUCT_CATEGORY_RELATIONSHIP('RPV','RPV-HEAD',#200);
#202 = PRODUCT_RELATED_PRODUCT_CATEGORY('nuclear pressure boundary',(#10,#20,#30,#40,#50,#60),#200);

/* ---- DESIGN PROPERTIES ---- */
#300 = PROPERTY_DEFINITION('mass','RPV total mass ~320 tonne',#12);
#301 = PROPERTY_DEFINITION('design_pressure','17.13 MPa primary system',#12);
#302 = PROPERTY_DEFINITION('design_temperature','343 degC',#12);
#303 = PROPERTY_DEFINITION('material_spec','SA-508 Gr3 / SA-533 GrB per ASME III',#12);
#304 = PROPERTY_DEFINITION('irradiation_fluence','<1.5E19 n/cm2 at 60yr EOL',#12);

ENDSEC;
END-ISO-10303-21;
