{
  "icd_version": "2.1.0",
  "system": "UAV-Flight-Control",
  "description": "Interface Control Document for tactical UAV flight control system",
  "date": "2024-03-15",
  "interfaces": [
    {
      "name": "FC-Pilot-DataLink",
      "protocol": "MAVLink v2",
      "description": "Primary command and telemetry link between ground station and flight controller",
      "signals": [
        "HEARTBEAT_TYPE",
        "HEARTBEAT_AUTOPILOT",
        "HEARTBEAT_BASE_MODE",
        "HEARTBEAT_CUSTOM_MODE",
        "HEARTBEAT_SYSTEM_STATUS",
        "ATTITUDE_ROLL",
        "ATTITUDE_PITCH",
        "ATTITUDE_YAW",
        "ATTITUDE_ROLLSPEED",
        "ATTITUDE_PITCHSPEED",
        "ATTITUDE_YAWSPEED",
        "GLOBAL_POSITION_LAT",
        "GLOBAL_POSITION_LON",
        "GLOBAL_POSITION_ALT",
        "GLOBAL_POSITION_RELATIVE_ALT",
        "GLOBAL_POSITION_VX",
        "GLOBAL_POSITION_VY",
        "GLOBAL_POSITION_VZ",
        "BATTERY_VOLTAGE",
        "BATTERY_CURRENT",
        "BATTERY_REMAINING",
        "GPS_FIX_TYPE",
        "GPS_SAT_COUNT",
        "GPS_HDOP",
        "GPS_VDOP",
        "RC_CHANNELS_CH1",
        "RC_CHANNELS_CH2",
        "RC_CHANNELS_CH3",
        "RC_CHANNELS_CH4"
      ]
    },
    {
      "name": "FC-Engine-Bus",
      "protocol": "CAN-FD",
      "description": "Engine control unit interface for propulsion monitoring",
      "signals": [
        "ENGINE_RPM",
        "ENGINE_TEMP",
        "ENGINE_OIL_PRESSURE",
        "ENGINE_FUEL_FLOW",
        "ENGINE_THROTTLE_POS",
        "ENGINE_EGT"
      ]
    },
    {
      "name": "FC-ADAS-Link",
      "protocol": "Ethernet",
      "description": "ADAS sensor fusion data link (LiDAR, radar, camera)",
      "signals": [
        "LIDAR_OBSTACLE_DIST",
        "LIDAR_OBSTACLE_ANGLE",
        "RADAR_TARGET_RANGE",
        "RADAR_TARGET_VELOCITY",
        "RADAR_TARGET_AZIMUTH",
        "VISION_LANE_DETECT",
        "VISION_LANE_OFFSET",
        "VISION_TRAFFIC_SIGN"
      ]
    }
  ],
