@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:  <http://www.w3.org/2002/07/owl#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
@prefix mbse: <http://vectorowl.org/ontology/mbse#> .
@prefix ex:   <http://vectorowl.org/demo/ap-v2#> .

# ─── Ontology ─────────────────────────────────────────────────────────────────
<http://vectorowl.org/demo/aircraft-propulsion-v2> a owl:Ontology ;
    rdfs:label "Aircraft Turbofan Propulsion — Instance Dataset" ;
    rdfs:comment "Instances for a high-bypass turbofan propulsion system MBSE model." .

# ─── Top-level system ─────────────────────────────────────────────────────────
ex:sys_turbofan a owl:NamedIndividual , mbse:System ;
    rdfs:label "CF-980 High-Bypass Turbofan" ;
    mbse:identifier "CF-980" ;
    mbse:thrustClass_kN "320"^^xsd:decimal ;
    mbse:bypassRatio "12.4"^^xsd:decimal ;
    mbse:overallPressureRatio "48.0"^^xsd:decimal ;
    mbse:turbineInletTemp_C "1620"^^xsd:decimal ;
    mbse:tier "1"^^xsd:integer ;
    mbse:status "In Development" .

# ─── Major Subsystems ─────────────────────────────────────────────────────────
ex:sub_fan a owl:NamedIndividual , mbse:Subsystem ;
    rdfs:label "Fan Module" ;
    mbse:identifier "SS-FAN" ;
    mbse:diameter_mm "3290"^^xsd:decimal ;
    mbse:bladeCount "18"^^xsd:integer ;
    mbse:fanPressureRatio "1.52"^^xsd:decimal ;
    mbse:mass_kg "820"^^xsd:decimal ;
    mbse:tier "2"^^xsd:integer ;
    mbse:partOf ex:sys_turbofan .

ex:sub_lpc a owl:NamedIndividual , mbse:Subsystem ;
    rdfs:label "Low-Pressure Compressor (Booster)" ;
    mbse:identifier "SS-LPC" ;
    mbse:stageCount "3"^^xsd:integer ;
    mbse:pressureRatio "2.1"^^xsd:decimal ;
    mbse:mass_kg "310"^^xsd:decimal ;
    mbse:tier "2"^^xsd:integer ;
    mbse:partOf ex:sys_turbofan .

ex:sub_hpc a owl:NamedIndividual , mbse:Subsystem ;
    rdfs:label "High-Pressure Compressor" ;
    mbse:identifier "SS-HPC" ;
    mbse:stageCount "10"^^xsd:integer ;
    mbse:pressureRatio "22.9"^^xsd:decimal ;
    mbse:mass_kg "540"^^xsd:decimal ;
    mbse:tier "2"^^xsd:integer ;
    mbse:partOf ex:sys_turbofan .

ex:sub_cc a owl:NamedIndividual , mbse:Subsystem ;
    rdfs:label "Combustion Chamber" ;
    mbse:identifier "SS-CC" ;
    mbse:fuelType "Jet-A" ;
    mbse:pressureLoss_pct "3.8"^^xsd:decimal ;
    mbse:mass_kg "195"^^xsd:decimal ;
    mbse:tier "2"^^xsd:integer ;
    mbse:partOf ex:sys_turbofan .

ex:sub_hpt a owl:NamedIndividual , mbse:Subsystem ;
    rdfs:label "High-Pressure Turbine" ;
    mbse:identifier "SS-HPT" ;
    mbse:stageCount "2"^^xsd:integer ;
    mbse:mass_kg "460"^^xsd:decimal ;
    mbse:tier "2"^^xsd:integer ;
    mbse:partOf ex:sys_turbofan .

ex:sub_lpt a owl:NamedIndividual , mbse:Subsystem ;
    rdfs:label "Low-Pressure Turbine" ;
    mbse:identifier "SS-LPT" ;
    mbse:stageCount "7"^^xsd:integer ;
    mbse:mass_kg "630"^^xsd:decimal ;
    mbse:tier "2"^^xsd:integer ;
    mbse:partOf ex:sys_turbofan .

ex:sub_fadec a owl:NamedIndividual , mbse:Subsystem ;
    rdfs:label "FADEC — Full Authority Digital Engine Control" ;
    mbse:identifier "SS-FADEC" ;
    mbse:softwarePartNumber "P0981-SW-4.2" ;
    mbse:processorFreq_MHz "400"^^xsd:decimal ;
    mbse:mass_kg "12.4"^^xsd:decimal ;
    mbse:tier "2"^^xsd:integer ;
    mbse:partOf ex:sys_turbofan .

ex:sub_oilsys a owl:NamedIndividual , mbse:Subsystem ;
    rdfs:label "Oil System" ;
    mbse:identifier "SS-OIL" ;
    mbse:tankCapacity_L "18.5"^^xsd:decimal ;
    mbse:mass_kg "28.0"^^xsd:decimal ;
    mbse:tier "2"^^xsd:integer ;
    mbse:partOf ex:sys_turbofan .

# ─── Key Components ───────────────────────────────────────────────────────────
ex:comp_fan_blade a owl:NamedIndividual , mbse:Component ;
    rdfs:label "Fan Blade (Wide Chord)" ;
    mbse:identifier "COMP-FAN-BLD" ;
    mbse:material "Ti-6Al-4V with CFRP face sheets" ;
    mbse:count "18"^^xsd:integer ;
    mbse:mass_kg "7.6"^^xsd:decimal ;
    mbse:tier "3"^^xsd:integer ;
    mbse:partOf ex:sub_fan .

ex:comp_hpt_blade a owl:NamedIndividual , mbse:Component ;
    rdfs:label "HPT Rotor Blade Stage 1" ;
    mbse:identifier "COMP-HPT-BLD1" ;
    mbse:material "Inconel 718 DS" ;
    mbse:coolingType "Film + impingement" ;
    mbse:count "72"^^xsd:integer ;
    mbse:tier "3"^^xsd:integer ;
    mbse:partOf ex:sub_hpt .

ex:comp_fuel_nozzle a owl:NamedIndividual , mbse:Component ;
    rdfs:label "Fuel Injection Nozzle" ;
    mbse:identifier "COMP-CC-NOZZ" ;
    mbse:count "24"^^xsd:integer ;
    mbse:flowRate_kg_s "0.062"^^xsd:decimal ;
    mbse:tier "3"^^xsd:integer ;
    mbse:partOf ex:sub_cc .

ex:comp_ecu a owl:NamedIndividual , mbse:Component ;
    rdfs:label "Engine Control Unit (ECU)" ;
    mbse:identifier "COMP-FADEC-ECU" ;
    mbse:redundancy "Dual-channel" ;
    mbse:mtbf_h "50000"^^xsd:decimal ;
    mbse:tier "3"^^xsd:integer ;
    mbse:partOf ex:sub_fadec .

# ─── Functions ────────────────────────────────────────────────────────────────
ex:fn_compress a owl:NamedIndividual , mbse:Function ;
    rdfs:label "Compress Intake Air" ;
    mbse:allocatedTo ex:sub_lpc ;
    mbse:allocatedTo ex:sub_hpc .

ex:fn_combust a owl:NamedIndividual , mbse:Function ;
    rdfs:label "Burn Fuel-Air Mixture" ;
    mbse:allocatedTo ex:sub_cc .

ex:fn_expand a owl:NamedIndividual , mbse:Function ;
    rdfs:label "Extract Work from Hot Gas" ;
    mbse:allocatedTo ex:sub_hpt ;
    mbse:allocatedTo ex:sub_lpt .

ex:fn_control a owl:NamedIndividual , mbse:Function ;
    rdfs:label "Regulate Engine Operating Envelope" ;
    mbse:allocatedTo ex:sub_fadec .

ex:fn_thrust a owl:NamedIndividual , mbse:Function ;
    rdfs:label "Generate Propulsive Thrust" ;
    mbse:allocatedTo ex:sub_fan .

# ─── Interfaces ───────────────────────────────────────────────────────────────
ex:iface_bleed_hpc_cc a owl:NamedIndividual , mbse:Interface ;
    rdfs:label "HPC→CC Bleed Interface" ;
    mbse:interfaceType "Bleed Air" ;
    mbse:from ex:sub_hpc ;
    mbse:to ex:sub_cc .

ex:iface_fadec_fuel a owl:NamedIndividual , mbse:Interface ;
    rdfs:label "FADEC→Fuel Metering Interface" ;
    mbse:interfaceType "PWM Control Signal" ;
    mbse:from ex:sub_fadec ;
    mbse:to ex:sub_cc .

ex:iface_hpt_lpt a owl:NamedIndividual , mbse:Interface ;
    rdfs:label "HPT→LPT Hot Gas Path" ;
    mbse:interfaceType "Hot Gas" ;
    mbse:from ex:sub_hpt ;
    mbse:to ex:sub_lpt .

# ─── Requirements ─────────────────────────────────────────────────────────────
ex:req_takeoff_thrust a owl:NamedIndividual , mbse:Requirement ;
    rdfs:label "Take-Off Thrust" ;
    mbse:identifier "REQ-PERF-001" ;
    mbse:text "The engine shall produce ≥ 320 kN sea-level static thrust at take-off rating (ISA, SL)." ;
    mbse:priority "High" ;
    mbse:status "Open" ;
    mbse:derivedFrom ex:sys_turbofan .

ex:req_tsfc a owl:NamedIndividual , mbse:Requirement ;
    rdfs:label "TSFC at Cruise" ;
    mbse:identifier "REQ-PERF-002" ;
    mbse:text "Thrust-specific fuel consumption shall be ≤ 0.0145 kg/(N·h) at cruise (FL350, M0.85)." ;
    mbse:priority "High" ;
    mbse:status "Open" .

ex:req_noise a owl:NamedIndividual , mbse:Requirement ;
    rdfs:label "Airport Noise" ;
    mbse:identifier "REQ-ENV-001" ;
    mbse:text "Engine noise shall meet ICAO Chapter 14 cumulative margin ≥ 10 EPNdB below limit." ;
    mbse:priority "High" ;
    mbse:status "Open" .

ex:req_reliability a owl:NamedIndividual , mbse:Requirement ;
    rdfs:label "IFSD Rate" ;
    mbse:identifier "REQ-REL-001" ;
    mbse:text "In-flight shutdown rate shall not exceed 0.001 per 1000 engine-flight-hours." ;
    mbse:priority "High" ;
    mbse:status "Open" .

ex:req_fadec_integrity a owl:NamedIndividual , mbse:Requirement ;
    rdfs:label "FADEC Safety Integrity" ;
    mbse:identifier "REQ-SAF-010" ;
    mbse:text "FADEC shall be certified to DAL A (RTCA DO-178C) with dual-channel redundancy." ;
    mbse:priority "High" ;
    mbse:status "In Progress" ;
    mbse:allocatedTo ex:sub_fadec .

# ─── Verification Cases ───────────────────────────────────────────────────────
ex:vc_thrust_test a owl:NamedIndividual , mbse:VerificationCase ;
    rdfs:label "Sea-Level Thrust Test" ;
    mbse:method "Test" ;
    mbse:verifies ex:req_takeoff_thrust ;
    mbse:status "Planned" .

ex:vc_noise_test a owl:NamedIndividual , mbse:VerificationCase ;
    rdfs:label "Certification Noise Measurement" ;
    mbse:method "Test" ;
    mbse:verifies ex:req_noise ;
    mbse:status "Planned" .

ex:vc_fadec_analysis a owl:NamedIndividual , mbse:VerificationCase ;
    rdfs:label "FADEC Failure Mode Analysis" ;
    mbse:method "Analysis" ;
    mbse:verifies ex:req_fadec_integrity ;
    mbse:status "In Progress" .

# ─── Hazards ──────────────────────────────────────────────────────────────────
ex:hazard_blade_off a owl:NamedIndividual , mbse:Hazard ;
    rdfs:label "Uncontained Fan Blade-Off" ;
    mbse:hazardClass "Catastrophic" ;
    mbse:mitigatedBy ex:sub_fadec ;
    mbse:description "A fan blade fractures and exits the nacelle casing." .

ex:hazard_hot_start a owl:NamedIndividual , mbse:Hazard ;
    rdfs:label "Hot Start / Hung Start" ;
    mbse:hazardClass "Hazardous" ;
    mbse:mitigatedBy ex:sub_fadec ;
    mbse:description "Excess fuel ignites during start, raising turbine temperature beyond limits." .
