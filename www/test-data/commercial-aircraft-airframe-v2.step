ISO-10303-21;
HEADER;
FILE_DESCRIPTION(('Commercial Transport Aircraft Airframe Assembly — Version 2'
  'AP214 Mechanical Design - Aerospace'
  'Aircraft: Narrow-body twin-engine commercial transport'
  'Assembly: Full airframe structural decomposition with sub-assemblies'
  'v2: adds individual slats/spoilers, floor structure, CWB, passenger doors,'
  '    MLG bogie, brake/wheel, NLG drag strut, hydraulic lines, APU detail'
  'Standard: MIL-STD-31000B, ARP4754A, AS9100D, ASTM E1235'),
  '2;1');
FILE_NAME('/aircraft/CommercialAirframe_Assembly_v2.step',
  '2026-06-10T10:00:00',
  ('Airframe Structures Group','Aerospace Systems Engineering'),
  ('VectorMBE CAD Export'),
  'VectorMBE STEP AP214 Exporter v2.4',
  'Commercial Airframe Rev B',
  'DISTRIBUTION UNLIMITED');
FILE_SCHEMA(('AUTOMOTIVE_DESIGN { 1 0 10303 214 3 1 1 1 }'));
ENDSEC;

