# Required — your VectorOWL license key
VECTOROWL_LICENSE_KEY=VOWL-XXXX-XXXX-XXXX-XXXX

# Multi-tenant isolation (demo/shared servers)
# Set to true so each API key gets its own isolated graph workspace.
# VECTOROWL_ISOLATE_BY_SESSION=true

# Optional: Qdrant persistent vector store for production-scale ANN
# Uncomment the qdrant service in docker-compose.yml first, then set this.
# VECTOROWL_QDRANT_URL=http://qdrant:6333

# Optional: LLM provider for AI synthesis and semantic embeddings
# VECTOROWL_LLM_PROVIDER=openai
# VECTOROWL_LLM_API_KEY=sk-...
# VECTOROWL_LLM_MODEL=gpt-4o
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# Optional: override default LLM endpoint (Ollama, Azure, etc.)
# VECTOROWL_LLM_ENDPOINT=http://localhost:11434/api/embeddings
